{
  "schemaVersion": 1,
  "id": "lacuna.audio",
  "name": "Lacuna Audio",
  "version": "0.1.0",
  "author": "Lacuna",
  "description": "Lacuna-styled PipeWire output control for the Omarchy bar.",
  "kinds": [
    "bar-widget"
  ],
  "activation": "on-demand",
  "entryPoints": {
    "barWidget": "Widget.qml"
  },
  "barWidget": {
    "displayName": "Lacuna Audio",
    "description": "Shows output volume and mute state.",
    "category": "Lacuna",
    "allowMultiple": false,
    "defaults": {
      "wheelStep": 5
    },
    "schema": [
      {
        "key": "wheelStep",
        "type": "integer",
        "label": "Wheel step (%)",
        "min": 1,
        "max": 25,
        "step": 1
      },
      {
        "key": "colorProfile",
        "type": "enum",
        "label": "Color profile",
        "options": [
          "semantic",
          "colorful"
        ],
        "description": "Override the global Lacuna color profile for this widget."
      }
    ]
  },
  "lacuna": {
    "standalone": true,
    "bundle": "standalone",
    "requires": [],
    "recommends": []
  }
}
