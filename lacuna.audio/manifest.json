{
  "schemaVersion": 1,
  "id": "lacuna.audio",
  "name": "Lacuna Audio",
  "version": "0.1.0",
  "author": "Lacuna",
  "description": "Lacuna audio provider, bar pill, and panel backed by PipeWire.",
  "kinds": [
    "service",
    "panel",
    "bar-widget"
  ],
  "activation": "persistent",
  "keepLoaded": true,
  "entryPoints": {
    "service": "Service.qml",
    "panel": "Panel.qml",
    "barWidget": "Widget.qml"
  },
  "barWidget": {
    "displayName": "Lacuna Audio",
    "description": "Shows output volume and mute state.",
    "category": "Lacuna",
    "allowMultiple": false,
    "defaults": {
      "wheelStep": 5,
      "colorProfile": "semantic"
    },
    "schema": [
      {
        "key": "wheelStep",
        "type": "integer",
        "label": "Wheel step (%)",
        "min": 1,
        "max": 25,
        "step": 1,
        "defaultValue": 5
      },
      {
        "key": "colorProfile",
        "type": "enum",
        "label": "Color profile",
        "options": [
          "semantic",
          "colorful"
        ],
        "description": "Override the global Lacuna color profile for this widget.",
        "defaultValue": "semantic"
      }
    ]
  },
  "lacuna": {
    "standalone": true,
    "bundle": "standalone",
    "requires": [],
    "recommends": []
  }
}
