{
  "schemaVersion": 1,
  "id": "lacuna.voxtype",
  "name": "Lacuna Voxtype",
  "version": "0.1.0",
  "author": "Lacuna",
  "description": "Lacuna-styled Voxtype dictation status module for the Omarchy bar.",
  "kinds": [
    "bar-widget"
  ],
  "activation": "on-demand",
  "entryPoints": {
    "barWidget": "Widget.qml"
  },
  "barWidget": {
    "displayName": "Lacuna Voxtype",
    "description": "Shows Voxtype recording and transcription state.",
    "category": "Lacuna",
    "allowMultiple": false,
    "defaults": {
      "showInactive": false,
      "colorProfile": "semantic"
    },
    "schema": [
      {
        "key": "showInactive",
        "type": "boolean",
        "label": "Show when inactive",
        "default": false,
        "defaultValue": false
      },
      {
        "key": "colorProfile",
        "type": "enum",
        "label": "Color profile",
        "options": [
          "semantic",
          "colorful"
        ],
        "description": "Override the global Lacuna color profile for this widget.",
        "defaultValue": "semantic"
      }
    ]
  },
  "lacuna": {
    "standalone": true,
    "bundle": "standalone",
    "requires": [],
    "recommends": []
  }
}
