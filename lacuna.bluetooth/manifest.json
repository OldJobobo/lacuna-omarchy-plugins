{
  "schemaVersion": 1,
  "id": "lacuna.bluetooth",
  "name": "Lacuna Bluetooth",
  "version": "0.1.0",
  "author": "Lacuna",
  "description": "Lacuna-styled Bluetooth control for the Omarchy bar.",
  "kinds": [
    "bar-widget"
  ],
  "activation": "on-demand",
  "entryPoints": {
    "barWidget": "Widget.qml"
  },
  "barWidget": {
    "displayName": "Lacuna Bluetooth",
    "description": "Shows Bluetooth adapter and connected-device state.",
    "category": "Lacuna",
    "allowMultiple": false,
    "defaults": {
      "colorProfile": "semantic"
    },
    "schema": [
      {
        "key": "colorProfile",
        "type": "enum",
        "label": "Color profile",
        "options": [
          "semantic",
          "colorful"
        ],
        "description": "Override the global Lacuna color profile for this widget.",
        "defaultValue": "semantic"
      }
    ]
  },
  "lacuna": {
    "standalone": true,
    "bundle": "standalone",
    "requires": [],
    "recommends": []
  }
}
