#!/usr/bin/env python3

import json
import os
import stat
import sys
import tempfile
import urllib.error
import urllib.request
from datetime import datetime, timezone
from pathlib import Path


SESSIONS_DIR = Path.home() / ".codex" / "sessions"
WINDOW_COHERENCE_SECONDS = 15 * 60
USAGE_ENDPOINT = "https://chatgpt.com/backend-api/wham/usage"
MAX_RESPONSE_BYTES = 1024 * 1024
CACHE_MAX_AGE_SECONDS = 12 * 60 * 60


def pi_agent_dir():
    return Path(os.environ.get("PI_CODING_AGENT_DIR") or (Path.home() / ".pi" / "agent"))


def cache_path():
    cache_home = Path(os.environ.get("XDG_CACHE_HOME") or (Path.home() / ".cache"))
    return cache_home / "lacuna" / "codex-usage.json"


def iter_session_files():
    if not SESSIONS_DIR.exists():
        return []

    paths = []
    for path in SESSIONS_DIR.rglob("*.jsonl"):
        try:
            paths.append((path.stat().st_mtime, path))
        except OSError:
            continue
    return [path for _, path in sorted(paths, reverse=True)]


def is_canonical_codex_limit(payload):
    rate_limits = payload.get("rate_limits") or {}
    return rate_limits.get("limit_id") == "codex"


def candidate_rank(candidate):
    return (
        1 if is_canonical_codex_limit(candidate["payload"]) else 0,
        candidate["timestamp_epoch"],
    )


def parse_timestamp(value):
    try:
        return datetime.fromisoformat(str(value).replace("Z", "+00:00")).timestamp()
    except (TypeError, ValueError):
        return None


def parse_latest_windows():
    candidates = []
    now = datetime.now(tz=timezone.utc).timestamp()

    for path in iter_session_files():
        try:
            with path.open("r", encoding="utf-8") as handle:
                for raw_line in handle:
                    try:
                        event = json.loads(raw_line)
                    except json.JSONDecodeError:
                        continue
                    if event.get("type") != "event_msg":
                        continue
                    payload = event.get("payload") or {}
                    timestamp = event.get("timestamp")
                    timestamp_epoch = parse_timestamp(timestamp)
                    if payload.get("type") != "token_count" or timestamp_epoch is None:
                        continue

                    rate_limits = payload.get("rate_limits") or {}
                    for key, legacy_minutes in (("primary", 300), ("secondary", 10080)):
                        window = rate_limits.get(key) or {}
                        if window.get("used_percent") is None:
                            continue
                        minutes = window.get("window_minutes")
                        if minutes is None:
                            minutes = legacy_minutes
                        if minutes not in (300, 10080):
                            continue
                        resets_at = window.get("resets_at")
                        if resets_at is not None and float(resets_at) < now:
                            continue
                        candidates.append({
                            "timestamp": timestamp,
                            "timestamp_epoch": timestamp_epoch,
                            "path": path,
                            "payload": payload,
                            "window": window,
                            "minutes": minutes,
                        })
        except OSError:
            continue

    best = {300: None, 10080: None}
    if not candidates:
        return best

    canonical = [candidate for candidate in candidates if is_canonical_codex_limit(candidate["payload"])]
    anchor = max(canonical or candidates, key=lambda candidate: candidate["timestamp_epoch"])

    # Codex may report the 5h and weekly windows in adjacent token_count events.
    # Combine those fresh split streams, but never resurrect an old 5h window
    # after the latest canonical event has stopped reporting it.
    for candidate in candidates:
        if abs(candidate["timestamp_epoch"] - anchor["timestamp_epoch"]) > WINDOW_COHERENCE_SECONDS:
            continue
        minutes = candidate["minutes"]
        current = best[minutes]
        if current is None or candidate_rank(candidate) > candidate_rank(current):
            best[minutes] = candidate

    return best


def secure_json_file(path):
    try:
        info = path.lstat()
    except OSError:
        return None
    if stat.S_ISLNK(info.st_mode) or not stat.S_ISREG(info.st_mode) or info.st_uid != os.getuid():
        return None
    if stat.S_IMODE(info.st_mode) & 0o077:
        return None
    try:
        with path.open("r", encoding="utf-8") as handle:
            return json.load(handle)
    except (OSError, json.JSONDecodeError):
        return None


def read_pi_credential():
    auth = secure_json_file(pi_agent_dir() / "auth.json")
    credential = auth.get("openai-codex") if isinstance(auth, dict) else None
    if not isinstance(credential, dict) or credential.get("type") != "oauth":
        return None
    access = credential.get("access")
    account_id = credential.get("accountId")
    if not isinstance(access, str) or not access or not isinstance(account_id, str) or not account_id:
        return None
    return access, account_id


def read_limited_json(response):
    length = response.headers.get("Content-Length")
    if length is not None and int(length) > MAX_RESPONSE_BYTES:
        raise ValueError("usage response is too large")
    payload = response.read(MAX_RESPONSE_BYTES + 1)
    if len(payload) > MAX_RESPONSE_BYTES:
        raise ValueError("usage response is too large")
    return json.loads(payload.decode("utf-8"))


def fetch_usage_payload():
    # Tests use a fixture and never read or transmit an OAuth credential.
    fixture = os.environ.get("LACUNA_CODEX_USAGE_API_FIXTURE")
    if fixture:
        with Path(fixture).open("r", encoding="utf-8") as handle:
            return json.load(handle)

    credential = read_pi_credential()
    if credential is None:
        return None
    access, account_id = credential
    request = urllib.request.Request(
        USAGE_ENDPOINT,
        headers={
            "Authorization": "Bearer " + access,
            "ChatGPT-Account-Id": account_id,
            "Accept": "application/json",
            "User-Agent": "lacuna-codex-usage/1.0",
        },
    )
    try:
        with urllib.request.urlopen(request, timeout=10) as response:
            if response.status != 200:
                return None
            return read_limited_json(response)
    except (OSError, ValueError, json.JSONDecodeError, urllib.error.URLError):
        return None


def bounded_percent(value):
    try:
        return max(0.0, min(100.0, float(value)))
    except (TypeError, ValueError):
        return None


def api_window_minutes(window):
    try:
        seconds = int(window.get("limit_window_seconds"))
    except (AttributeError, TypeError, ValueError):
        return None
    minutes = seconds // 60
    return minutes if minutes in (300, 10080) else None


def parse_api_usage(payload):
    if not isinstance(payload, dict):
        return None
    rate_limit = payload.get("rate_limit")
    if not isinstance(rate_limit, dict):
        return None

    windows = {}
    for key in ("primary_window", "secondary_window"):
        window = rate_limit.get(key)
        minutes = api_window_minutes(window)
        used = bounded_percent(window.get("used_percent")) if isinstance(window, dict) else None
        if minutes is None or used is None:
            continue
        try:
            reset_at = int(window.get("reset_at")) if window.get("reset_at") is not None else None
        except (TypeError, ValueError):
            reset_at = None
        windows[str(minutes)] = {"used_percent": used, "resets_at": reset_at}

    if not windows:
        return None
    now = datetime.now(tz=timezone.utc)
    return {
        "version": 1,
        "fetched_at": int(now.timestamp()),
        "source_event": now.isoformat().replace("+00:00", "Z"),
        "source": "OpenAI usage API via Pi OAuth",
        "plan_type": str(payload.get("plan_type") or "unknown"),
        "windows": windows,
    }


def write_sanitized_cache(data):
    path = cache_path()
    try:
        path.parent.mkdir(mode=0o700, parents=True, exist_ok=True)
        os.chmod(path.parent, 0o700)
        with tempfile.NamedTemporaryFile(
            mode="w",
            encoding="utf-8",
            dir=path.parent,
            prefix=path.name + ".",
            delete=False,
        ) as handle:
            os.fchmod(handle.fileno(), 0o600)
            json.dump(data, handle, separators=(",", ":"))
            handle.write("\n")
            temp_path = Path(handle.name)
        os.replace(temp_path, path)
        os.chmod(path, 0o600)
    except OSError:
        try:
            temp_path.unlink(missing_ok=True)
        except (NameError, OSError):
            pass


def read_sanitized_cache():
    data = secure_json_file(cache_path())
    if not isinstance(data, dict) or data.get("version") != 1:
        return None
    try:
        age = datetime.now(tz=timezone.utc).timestamp() - float(data.get("fetched_at"))
    except (TypeError, ValueError):
        return None
    if age < 0 or age > CACHE_MAX_AGE_SECONDS or not isinstance(data.get("windows"), dict):
        return None
    cached = dict(data)
    cached["source"] = "OpenAI usage API via Pi OAuth (cached)"
    return cached


def local_usage():
    windows = parse_latest_windows()
    selected = [event for event in windows.values() if event is not None]
    if not selected:
        return None
    latest = max(selected, key=lambda event: event["timestamp_epoch"])
    rate_limits = latest["payload"].get("rate_limits") or {}
    parsed_windows = {}
    for minutes, event in windows.items():
        if event is None:
            continue
        window = event["window"]
        used = bounded_percent(window.get("used_percent"))
        if used is None:
            continue
        parsed_windows[str(minutes)] = {
            "used_percent": used,
            "resets_at": window.get("resets_at"),
        }
    if not parsed_windows:
        return None
    return {
        "version": 1,
        "source_event": latest["timestamp"],
        "source_file": str(latest["path"]),
        "source": "local Codex token_count event",
        "plan_type": str(rate_limits.get("plan_type") or "unknown"),
        "windows": parsed_windows,
    }


def format_reset_time(epoch_seconds):
    if epoch_seconds is None:
        return "unknown"
    dt = datetime.fromtimestamp(float(epoch_seconds), tz=timezone.utc).astimezone()
    return dt.strftime("%Y-%m-%d %I:%M:%S %p %Z")


def emit_usage(data):
    windows = data.get("windows") or {}
    session = windows.get("300") or {}
    weekly = windows.get("10080") or {}
    session_used = bounded_percent(session.get("used_percent"))
    weekly_used = bounded_percent(weekly.get("used_percent"))
    if session_used is None and weekly_used is None:
        return 1

    if session_used is not None:
        print(f"5h limit left: {max(0.0, 100.0 - session_used):.1f}%")
        print(f"5h used: {session_used:.1f}%")
        print(f"5h resets: {format_reset_time(session.get('resets_at'))}")
    if weekly_used is not None:
        print(f"Weekly limit left: {max(0.0, 100.0 - weekly_used):.1f}%")
        print(f"Weekly used: {weekly_used:.1f}%")
        print(f"Weekly resets: {format_reset_time(weekly.get('resets_at'))}")

    print(f"Plan: {data.get('plan_type') or 'unknown'}")
    print(f"Source: {data.get('source') or 'unknown'}")
    if data.get("source_event"):
        print(f"Source event: {data['source_event']}")
    if data.get("source_file"):
        print(f"Source file: {data['source_file']}")
    return 0


def main():
    payload = fetch_usage_payload()
    api_usage = parse_api_usage(payload)
    if api_usage is not None:
        write_sanitized_cache(api_usage)
        return emit_usage(api_usage)

    cached = read_sanitized_cache()
    if cached is not None:
        return emit_usage(cached)

    local = local_usage()
    if local is not None:
        return emit_usage(local)

    print("No current OpenAI or local Codex usage windows found", file=sys.stderr)
    return 1


if __name__ == "__main__":
    raise SystemExit(main())
