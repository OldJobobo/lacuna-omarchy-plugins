#!/usr/bin/env python3

import json
import sys
from datetime import datetime, timezone
from pathlib import Path


SESSIONS_DIR = Path.home() / ".codex" / "sessions"
WINDOW_COHERENCE_SECONDS = 15 * 60


def iter_session_files():
    if not SESSIONS_DIR.exists():
        return []

    paths = []
    for path in SESSIONS_DIR.rglob("*.jsonl"):
        try:
            paths.append((path.stat().st_mtime, path))
        except OSError:
            continue
    return [path for _, path in sorted(paths, reverse=True)]


def is_canonical_codex_limit(payload):
    rate_limits = payload.get("rate_limits") or {}
    return rate_limits.get("limit_id") == "codex"


def candidate_rank(candidate):
    return (
        1 if is_canonical_codex_limit(candidate["payload"]) else 0,
        candidate["timestamp_epoch"],
    )


def parse_timestamp(value):
    try:
        return datetime.fromisoformat(str(value).replace("Z", "+00:00")).timestamp()
    except (TypeError, ValueError):
        return None


def parse_latest_token_count():
    best = None

    for path in iter_session_files():
        try:
            with path.open("r", encoding="utf-8") as handle:
                for raw_line in handle:
                    raw_line = raw_line.strip()
                    if not raw_line:
                        continue

                    try:
                        event = json.loads(raw_line)
                    except json.JSONDecodeError:
                        continue

                    if event.get("type") != "event_msg":
                        continue

                    payload = event.get("payload") or {}
                    if payload.get("type") != "token_count":
                        continue

                    timestamp = event.get("timestamp")
                    if not timestamp:
                        continue
                    timestamp_epoch = parse_timestamp(timestamp)
                    if timestamp_epoch is None:
                        continue

                    candidate = {
                        "timestamp": timestamp,
                        "timestamp_epoch": timestamp_epoch,
                        "path": path,
                        "payload": payload,
                    }
                    if best is None or candidate_rank(candidate) > candidate_rank(best):
                        best = candidate
        except OSError:
            continue

    return best


def parse_latest_windows():
    candidates = []
    now = datetime.now(tz=timezone.utc).timestamp()

    for path in iter_session_files():
        try:
            with path.open("r", encoding="utf-8") as handle:
                for raw_line in handle:
                    try:
                        event = json.loads(raw_line)
                    except json.JSONDecodeError:
                        continue
                    if event.get("type") != "event_msg":
                        continue
                    payload = event.get("payload") or {}
                    timestamp = event.get("timestamp")
                    timestamp_epoch = parse_timestamp(timestamp)
                    if payload.get("type") != "token_count" or timestamp_epoch is None:
                        continue

                    rate_limits = payload.get("rate_limits") or {}
                    for key, legacy_minutes in (("primary", 300), ("secondary", 10080)):
                        window = rate_limits.get(key) or {}
                        if window.get("used_percent") is None:
                            continue
                        minutes = window.get("window_minutes")
                        if minutes is None:
                            minutes = legacy_minutes
                        if minutes not in (300, 10080):
                            continue
                        resets_at = window.get("resets_at")
                        if resets_at is not None and float(resets_at) < now:
                            continue
                        candidate = {
                            "timestamp": timestamp,
                            "timestamp_epoch": timestamp_epoch,
                            "path": path,
                            "payload": payload,
                            "window": window,
                            "minutes": minutes,
                        }
                        candidates.append(candidate)
        except OSError:
            continue

    best = {300: None, 10080: None}
    if not candidates:
        return best

    canonical = [candidate for candidate in candidates if is_canonical_codex_limit(candidate["payload"])]
    anchor = max(canonical or candidates, key=lambda candidate: candidate["timestamp_epoch"])

    # Codex may report the 5h and weekly windows in adjacent token_count events.
    # Combine those fresh split streams, but never resurrect an old 5h window
    # after the latest canonical event has stopped reporting it.
    for candidate in candidates:
        if abs(candidate["timestamp_epoch"] - anchor["timestamp_epoch"]) > WINDOW_COHERENCE_SECONDS:
            continue
        minutes = candidate["minutes"]
        current = best[minutes]
        if current is None or candidate_rank(candidate) > candidate_rank(current):
            best[minutes] = candidate

    return best


def format_reset_time(epoch_seconds):
    if epoch_seconds is None:
        return "unknown"
    dt = datetime.fromtimestamp(epoch_seconds, tz=timezone.utc).astimezone()
    return dt.strftime("%Y-%m-%d %I:%M:%S %p %Z")


def limit_window(rate_limits, window_minutes, legacy_key):
    windows = []
    for key in ("primary", "secondary"):
        window = rate_limits.get(key) or {}
        if window:
            windows.append(window)
        if window.get("window_minutes") == window_minutes:
            return window

    # Older Codex events omitted window_minutes and used fixed positions.
    if windows and all(window.get("window_minutes") is None for window in windows):
        return rate_limits.get(legacy_key) or {}
    return {}


def main():
    windows = parse_latest_windows()
    session_event = windows[300]
    weekly_event = windows[10080]
    selected = [event for event in (session_event, weekly_event) if event is not None]
    if not selected:
        print("No Codex token_count events found in ~/.codex/sessions", file=sys.stderr)
        return 1

    latest = max(selected, key=lambda event: event["timestamp"])
    session = session_event["window"] if session_event else {}
    weekly = weekly_event["window"] if weekly_event else {}
    session_used_percent = session.get("used_percent")
    session_reset_at = session.get("resets_at")
    weekly_used_percent = weekly.get("used_percent")
    weekly_reset_at = weekly.get("resets_at")
    rate_limits = latest["payload"].get("rate_limits") or {}
    plan_type = rate_limits.get("plan_type") or "unknown"

    if weekly_used_percent is None and session_used_percent is None:
        print("Latest token_count event does not include primary or secondary used_percent", file=sys.stderr)
        return 1

    source = latest["path"]
    timestamp = latest["timestamp"]

    if session_used_percent is not None:
        session_left_percent = max(0.0, 100.0 - float(session_used_percent))
        print(f"5h limit left: {session_left_percent:.1f}%")
        print(f"5h used: {float(session_used_percent):.1f}%")
        print(f"5h resets: {format_reset_time(session_reset_at)}")

    if weekly_used_percent is not None:
        weekly_left_percent = max(0.0, 100.0 - float(weekly_used_percent))
        print(f"Weekly limit left: {weekly_left_percent:.1f}%")
        print(f"Weekly used: {float(weekly_used_percent):.1f}%")
        print(f"Weekly resets: {format_reset_time(weekly_reset_at)}")

    print(f"Plan: {plan_type}")
    print(f"Source event: {timestamp}")
    print(f"Source file: {source}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
