{
  "version": 1,
  "bar": {
    "position": "top",
    "centerAnchor": "omarchy.clock",
    "layout": {
      "left": [
        { "id": "omarchy.menu" },
        { "id": "lacuna.workspaces", "workspaceCount": 7 },
        { "id": "lacuna.codex-usage", "interval": 300000, "showIcon": true },
        { "id": "lacuna.claude-usage", "interval": 30000, "showIcon": true },
        { "id": "lacuna.mpris", "maxTextLength": 34, "sweepOnPlaying": true },
        { "id": "lacuna.bar-size-pill" }
      ],
      "center": [
        { "id": "omarchy.clock" }
      ],
      "right": [
        { "id": "omarchy.tray" },
        { "id": "omarchy.bluetooth" },
        { "id": "omarchy.network" },
        { "id": "omarchy.audio" },
        { "id": "omarchy.power" },
        { "id": "lacuna.theme" },
        { "id": "lacuna.wallpaper" },
        { "id": "lacuna.system-stats" },
        { "id": "lacuna.temperature", "warmF": 150, "criticalF": 185 },
        { "id": "omarchy.indicators" }
      ]
    }
  },
  "plugins": [
    { "id": "lacuna.state" },
    { "id": "lacuna.shell-settings" },
    { "id": "lacuna.settings-persistence" }
  ]
}
