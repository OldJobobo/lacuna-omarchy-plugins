{
  "version": 1,
  "bar": {
    "position": "top",
    "transparent": false,
    "centerAnchor": "lacuna.clock",
    "layout": {
      "left": [
        { "id": "lacuna.menu-button" },
        { "id": "omarchy.spacer", "size": 24 },
        { "id": "lacuna.workspaces", "workspaceCount": 7 },
        { "id": "omarchy.spacer", "size": 24 },
        { "id": "lacuna.codex-usage" },
        { "id": "lacuna.claude-usage" },
        { "id": "omarchy.spacer", "size": 24 },
        { "id": "lacuna.mpris" }
      ],
      "center": [
        { "id": "lacuna.system-update" },
        {
          "id": "lacuna.clock",
          "format": "ddd d h:mm AP",
          "formatAlt": "dd MMMM 'W'ww yyyy",
          "verticalFormat": "HH\n—\nmm"
        },
        { "id": "lacuna.weather" },
        { "id": "lacuna.notifications" },
        { "id": "lacuna.nightlight" },
        { "id": "lacuna.idle-inhibitor" },
        { "id": "lacuna.screen-recording" },
        { "id": "lacuna.voxtype" }
      ],
      "right": [
        { "id": "lacuna.tray" },
        { "id": "lacuna.theme" },
        { "id": "lacuna.wallpaper" },
        { "id": "lacuna.bluetooth" },
        { "id": "lacuna.network" },
        { "id": "lacuna.audio" },
        { "id": "lacuna.power" },
        { "id": "lacuna.system-stats" },
        { "id": "lacuna.temperature" },
        { "id": "lacuna.bar-size-pill" }
      ]
    }
  },
  "plugins": [
    { "id": "lacuna.menu" },
    { "id": "lacuna.theme-preloader" },
    { "id": "lacuna.desktop-clock" },
    { "id": "lacuna.vhs-overlay" },
    { "id": "lacuna.crt-overlay" },
    { "id": "lacuna.aurora-drift" },
    { "id": "lacuna.rainfall-overlay" },
    { "id": "lacuna.cinematic-light-overlay" },
    { "id": "lacuna.background-vignette" },
    { "id": "lacuna.settings-persistence" },
    { "id": "lacuna.state" },
    { "id": "lacuna.shell-settings" },
    { "id": "lacuna.nightlight" },
    { "id": "lacuna.idle-inhibitor" },
    { "id": "lacuna.screen-recording" },
    { "id": "lacuna.voxtype" }
  ]
}
