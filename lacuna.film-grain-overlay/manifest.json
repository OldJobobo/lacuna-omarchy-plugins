{
  "schemaVersion": 1,
  "id": "lacuna.film-grain-overlay",
  "name": "Lacuna Film Grain Overlay",
  "version": "0.1.0",
  "author": "Lacuna",
  "description": "Fine animated film grain for subtle desktop texture.",
  "kinds": [
    "overlay"
  ],
  "activation": "persistent",
  "keepLoaded": true,
  "entryPoints": {
    "overlay": "Overlay.qml"
  },
  "defaults": {
    "effectEnabled": true,
    "intensity": 0.28,
    "speed": 1,
    "grainCount": 180,
    "grainSize": 1.35,
    "accentBlend": 0.18
  },
  "schema": [
    {
      "key": "effectEnabled",
      "type": "boolean",
      "label": "Effect enabled",
      "defaultValue": true
    },
    {
      "key": "intensity",
      "type": "number",
      "label": "Intensity",
      "defaultValue": 0.28
    },
    {
      "key": "speed",
      "type": "number",
      "label": "Speed",
      "defaultValue": 1
    },
    {
      "key": "grainCount",
      "type": "number",
      "label": "Grain count",
      "defaultValue": 180
    },
    {
      "key": "grainSize",
      "type": "number",
      "label": "Grain size",
      "defaultValue": 1.35
    },
    {
      "key": "accentBlend",
      "type": "number",
      "label": "Accent blend",
      "defaultValue": 0.18
    }
  ],
  "lacuna": {
    "standalone": true,
    "bundle": "standalone",
    "requires": [],
    "recommends": []
  }
}
