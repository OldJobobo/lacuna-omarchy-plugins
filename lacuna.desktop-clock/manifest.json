{
  "schemaVersion": 1,
  "id": "lacuna.desktop-clock",
  "name": "Lacuna Desktop Clock",
  "version": "0.1.0",
  "author": "Lacuna",
  "description": "Large Tektur digital clock rendered on the desktop layer.",
  "kinds": [
    "overlay"
  ],
  "activation": "persistent",
  "keepLoaded": true,
  "entryPoints": {
    "overlay": "Clock.qml"
  },
  "defaults": {
    "anchor": "bottom-right",
    "offsetX": 0,
    "offsetY": 0,
    "scale": 1,
    "use12Hour": false
  },
  "schema": [
    {
      "key": "anchor",
      "type": "select",
      "label": "Anchor",
      "options": [
        "top-left",
        "top",
        "top-right",
        "left",
        "center",
        "right",
        "bottom-left",
        "bottom",
        "bottom-right"
      ],
      "defaultValue": "bottom-right"
    },
    {
      "key": "offsetX",
      "type": "number",
      "label": "Horizontal offset",
      "defaultValue": 0
    },
    {
      "key": "offsetY",
      "type": "number",
      "label": "Vertical offset",
      "defaultValue": 0
    },
    {
      "key": "scale",
      "type": "number",
      "label": "Scale",
      "defaultValue": 1
    },
    {
      "key": "use12Hour",
      "type": "boolean",
      "label": "12-hour time",
      "defaultValue": false
    }
  ],
  "lacuna": {
    "standalone": true,
    "bundle": "standalone",
    "requires": [],
    "recommends": []
  }
}
