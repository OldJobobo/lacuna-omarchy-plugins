{
  "version": 1,
  "designStyle": "carbon",
  "colorProfile": "semantic",
  "compact": false,
  "barSizeMode": "theme",
  "quickLaunchLayout": "grid",
  "dailyLaunchLayout": "list",
  "shortcutsLayout": "grid",
  "controlsLayout": "grid",
  "barSizeSnapshot": {
    "themeName": "fixture-theme",
    "sizeHorizontal": 30,
    "sizeVertical": 32
  },
  "sizeTransition": {
    "holdCompact": false,
    "holdUntil": 0
  },
  "customQuickLaunchApps": [
    "firefox.desktop",
    "org.wezfurlong.wezterm.desktop",
    "code.desktop"
  ],
  "customQuickLaunchNames": {
    "firefox.desktop": "Browser",
    "org.wezfurlong.wezterm.desktop": "Terminal",
    "code.desktop": "Editor"
  },
  "preferredApps": {
    "files": "org.gnome.Nautilus.desktop",
    "editor": "code.desktop",
    "email": "thunderbird.desktop",
    "discord": "vesktop.desktop"
  },
  "power": {
    "instantRestart": false
  },
  "shellSettings": {
    "surface": "flyout"
  },
  "mediaProviders": {
    "youtube": {
      "enabled": true,
      "cookiesFromBrowser": "firefox",
      "cookiesFile": ""
    },
    "jellyfin": {
      "enabled": true,
      "serverUrl": "https://jellyfin.example",
      "apiKey": "fixture-api-key",
      "userId": "fixture-user"
    }
  },
  "sidebar": {
    "defaultMode": "rail",
    "collapsed": true,
    "exclusive": false,
    "cornerPieces": false
  },
    "backgroundEffects": {
        "enabled": true,
        "foregroundOverlay": false,
        "opacity": 0.92,
        "activeEffect": "auroraDrift",
        "effects": {
            "trackingLines": {
                "enabled": true
            },
            "filmGrain": {
                "enabled": true,
                "intensity": 0.42,
                "speed": 1.1,
                "grainCount": 220,
                "grainSize": 1.6,
                "accentBlend": 0.25
            },
            "auroraDrift": {
                "enabled": true
            },
      "rainfall": {
        "enabled": true
      },
      "cinematicLight": {
        "enabled": true
      },
      "godRays": {
        "enabled": true
      },
      "crt": {
        "enabled": true
      }
    }
  },
  "backgroundVignette": {
    "enabled": true,
    "intensity": 0.85,
    "ignoreBackgroundAnimationLayer": false
  },
  "frame": {
    "mode": "fullframe",
    "reserveMode": "comfort",
    "shadow": true,
    "border": true,
    "thickness": 10,
    "radius": 16,
    "shadowDirection": "bottom_right",
    "shadowOffsetX": 2,
    "shadowOffsetY": 3
  }
}
