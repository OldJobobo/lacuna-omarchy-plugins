{
  "version": 1,
  "designStyle": "carbon",
  "colorProfile": "semantic",
  "compact": false,
  "barSizeMode": "theme",
  "quickLaunchLayout": "grid",
  "dailyLaunchLayout": "list",
  "shortcutsLayout": "grid",
  "controlsLayout": "grid",
  "barSizeSnapshot": {
    "themeName": "fixture-theme",
    "sizeHorizontal": 30,
    "sizeVertical": 32
  },
  "sizeTransition": {
    "holdCompact": false,
    "holdUntil": 0
  },
  "customQuickLaunchApps": [
    "firefox.desktop",
    "org.wezfurlong.wezterm.desktop",
    "code.desktop"
  ],
  "customQuickLaunchNames": {
    "firefox.desktop": "Browser",
    "org.wezfurlong.wezterm.desktop": "Terminal",
    "code.desktop": "Editor"
  },
  "preferredApps": {
    "files": "org.gnome.Nautilus.desktop",
    "editor": "code.desktop",
    "email": "thunderbird.desktop",
    "discord": "vesktop.desktop"
  },
  "power": {
    "instantRestart": false
  },
  "shellSettings": {
    "surface": "flyout"
  },
  "sidebar": {
    "defaultMode": "rail",
    "collapsed": true,
    "exclusive": false,
    "cornerPieces": false
  },
  "backgroundEffects": {
    "enabled": true,
    "activeEffect": "auroraDrift",
    "effects": {
      "trackingLines": {
        "enabled": true
      },
      "auroraDrift": {
        "enabled": true
      },
      "rainfall": {
        "enabled": true
      },
      "cinematicLight": {
        "enabled": true
      }
    }
  },
  "frame": {
    "mode": "fullframe",
    "shadow": true,
    "thickness": 10,
    "radius": 16,
    "shadowDirection": "bottom_right",
    "shadowOffsetX": 2,
    "shadowOffsetY": 3
  }
}
