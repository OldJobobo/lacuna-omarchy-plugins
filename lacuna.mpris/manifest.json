{
  "schemaVersion": 1,
  "id": "lacuna.mpris",
  "name": "Lacuna MPRIS",
  "version": "0.1.0",
  "author": "Lacuna",
  "description": "Original Lacuna-styled MPRIS media pill with sweeping playback text.",
  "kinds": [
    "bar-widget"
  ],
  "activation": "on-demand",
  "entryPoints": {
    "barWidget": "Widget.qml"
  },
  "barWidget": {
    "displayName": "Lacuna MPRIS",
    "description": "Recreates the original Lacuna media pill and sweep animation.",
    "category": "Lacuna",
    "allowMultiple": false,
    "defaults": {
      "maxTextLength": 34,
      "sweepOnPlaying": true,
      "hideWhenVertical": true,
      "colorProfile": "semantic"
    },
    "schema": [
      {
        "key": "maxTextLength",
        "type": "integer",
        "label": "Maximum text length",
        "min": 8,
        "max": 80,
        "step": 1,
        "defaultValue": 34
      },
      {
        "key": "sweepOnPlaying",
        "type": "boolean",
        "label": "Sweep text while playing",
        "defaultValue": true
      },
      {
        "key": "hideWhenVertical",
        "type": "boolean",
        "label": "Hide on vertical bars",
        "defaultValue": true
      },
      {
        "key": "colorProfile",
        "type": "enum",
        "label": "Color profile",
        "options": [
          "semantic",
          "colorful"
        ],
        "description": "Override the global Lacuna color profile for this widget.",
        "defaultValue": "semantic"
      }
    ]
  },
  "lacuna": {
    "standalone": true,
    "bundle": "standalone",
    "vendorExclude": [
      "ColorProfile.qml",
      "components/MotionTokens.qml"
    ],
    "requires": [],
    "recommends": []
  }
}
