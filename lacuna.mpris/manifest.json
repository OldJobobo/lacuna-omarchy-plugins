{
  "schemaVersion": 1,
  "id": "lacuna.mpris",
  "name": "Lacuna MPRIS",
  "version": "0.1.0",
  "author": "Lacuna",
  "description": "Original Lacuna-styled MPRIS media pill with sweeping playback text.",
  "kinds": [
    "bar-widget"
  ],
  "activation": "on-demand",
  "entryPoints": {
    "barWidget": "Widget.qml"
  },
  "barWidget": {
    "displayName": "Lacuna MPRIS",
    "description": "Recreates the original Lacuna media pill and sweep animation.",
    "category": "Lacuna",
    "allowMultiple": false,
    "defaults": {
      "maxTextLength": 34,
      "sweepOnPlaying": true,
      "hideWhenVertical": true
    },
    "schema": [
      {
        "key": "maxTextLength",
        "type": "integer",
        "label": "Maximum text length",
        "min": 8,
        "max": 80,
        "step": 1
      },
      {
        "key": "sweepOnPlaying",
        "type": "boolean",
        "label": "Sweep text while playing"
      },
      {
        "key": "hideWhenVertical",
        "type": "boolean",
        "label": "Hide on vertical bars"
      },
      {
        "key": "colorProfile",
        "type": "enum",
        "label": "Color profile",
        "options": [
          "semantic",
          "colorful"
        ],
        "description": "Override the global Lacuna color profile for this widget."
      }
    ]
  },
  "lacuna": {
    "standalone": true,
    "bundle": "standalone",
    "requires": [],
    "recommends": []
  }
}
