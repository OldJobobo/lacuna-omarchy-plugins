{
  "schemaVersion": 1,
  "id": "lacuna.clock",
  "name": "Lacuna Clock",
  "version": "0.1.0",
  "author": "Lacuna",
  "description": "Lacuna-styled clock for the Omarchy bar.",
  "kinds": [
    "bar-widget"
  ],
  "activation": "on-demand",
  "entryPoints": {
    "barWidget": "Widget.qml"
  },
  "barWidget": {
    "displayName": "Lacuna Clock",
    "description": "Shows the current time and opens a read-only month calendar.",
    "category": "Lacuna",
    "allowMultiple": false,
    "defaults": {
      "format": "ddd d h:mm AP",
      "dateFormat": "ddd d",
      "timeFormat": "h:mm AP",
      "verticalFormat": "HH\n\u2014\nmm",
      "colorProfile": "semantic"
    },
    "schema": [
      {
        "key": "format",
        "type": "string",
        "label": "Horizontal format",
        "defaultValue": "ddd d h:mm AP"
      },
      {
        "key": "dateFormat",
        "type": "string",
        "label": "Date format",
        "defaultValue": "ddd d"
      },
      {
        "key": "timeFormat",
        "type": "string",
        "label": "Time format",
        "defaultValue": "h:mm AP"
      },
      {
        "key": "verticalFormat",
        "type": "string",
        "label": "Vertical format",
        "defaultValue": "HH\n\u2014\nmm"
      },
      {
        "key": "colorProfile",
        "type": "enum",
        "label": "Color profile",
        "options": [
          "semantic",
          "colorful"
        ],
        "description": "Override the global Lacuna color profile for this widget.",
        "defaultValue": "semantic"
      }
    ]
  },
  "lacuna": {
    "standalone": true,
    "bundle": "standalone",
    "requires": [],
    "recommends": []
  }
}
