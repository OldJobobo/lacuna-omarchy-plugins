{
  "schemaVersion": 1,
  "id": "lacuna.bar",
  "name": "Lacuna Bar",
  "version": "0.1.0",
  "author": "Lacuna",
  "description": "Lacuna's primary Omarchy bar host with frame-aware surface ownership.",
  "kinds": [
    "bar"
  ],
  "entryPoints": {
    "bar": "Bar.qml"
  },
  "lacuna": {
