{
  "schemaVersion": 1,
  "id": "lacuna.theme",
  "name": "Lacuna Theme",
  "version": "0.1.0",
  "author": "Lacuna",
  "description": "Lacuna-styled top-bar widget for the active Omarchy theme.",
  "kinds": [
    "bar-widget"
  ],
  "activation": "on-demand",
  "entryPoints": {
    "barWidget": "Widget.qml"
  },
  "barWidget": {
    "displayName": "Lacuna Theme",
    "description": "Shows the active palette and opens a Lacuna theme-details flyout.",
    "category": "Lacuna",
    "allowMultiple": false,
    "defaults": {
      "enabled": true,
      "maxTextLength": 22,
      "colorProfile": "semantic"
    },
    "schema": [
      {
        "key": "enabled",
        "type": "boolean",
        "label": "Enabled",
        "defaultValue": true
      },
      {
        "key": "maxTextLength",
        "type": "integer",
        "label": "Max title length",
        "min": 8,
        "max": 48,
        "step": 1,
        "defaultValue": 22
      },
      {
        "key": "colorProfile",
        "type": "enum",
        "label": "Color profile",
        "options": [
          "semantic",
          "colorful"
        ],
        "defaultValue": "semantic",
        "description": "Override the global Lacuna color profile for this widget."
      }
    ]
  },
  "lacuna": {
    "standalone": true,
    "bundle": "standalone",
    "vendorExclude": [
      "ColorProfile.qml"
    ],
    "requires": [],
    "recommends": [
      "lacuna.theme-preloader"
    ]
  }
}
