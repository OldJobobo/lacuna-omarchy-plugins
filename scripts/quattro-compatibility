#!/usr/bin/env python3
"""Report whether this checkout matches the supported Omarchy Quattro host."""

from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import subprocess
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]
OMARCHY_ROOT = Path(os.environ.get("OMARCHY_PATH", Path.home() / ".local/share/omarchy"))
REVIEW_FILE = ROOT / "config/quattro-compatibility.json"
BAR_FILES = {
    "Bar.qml": OMARCHY_ROOT / "shell/plugins/bar/Bar.qml",
    "BarModel.js": OMARCHY_ROOT / "shell/plugins/bar/BarModel.js",
    "shell.qml": OMARCHY_ROOT / "shell/shell.qml",
}
CORE_PLUGINS = ["lacuna.bar", "lacuna.state", "lacuna.shell-settings", "lacuna.menu"]


def command_output(command: list[str]) -> str:
    try:
        result = subprocess.run(
            command,
            check=False,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            timeout=15,
        )
    except (OSError, subprocess.TimeoutExpired):
        return ""
    return result.stdout.strip()


def package_version(name: str) -> str:
    raw = command_output(["pacman", "-Qi", name])
    match = re.search(r"^Version\s+:\s*(\S+)", raw, re.MULTILINE)
    return match.group(1) if match else "unknown"


def sha256(path: Path) -> str:
    import hashlib

    digest = hashlib.sha256()
    with path.open("rb") as handle:
        for chunk in iter(lambda: handle.read(1024 * 1024), b""):
            digest.update(chunk)
    return digest.hexdigest()


def vendored_parity() -> bool | None:
    checker = ROOT / "scripts/sync-vendored"
    if not checker.exists():
        return False
    try:
        result = subprocess.run(
            [str(checker), "--check"],
            cwd=ROOT,
            check=False,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            timeout=30,
        )
    except (OSError, subprocess.TimeoutExpired):
        return None
    return result.returncode == 0


def plugin_validation() -> dict[str, str]:
    if shutil.which("omarchy") is None:
        return {plugin_id: "unavailable" for plugin_id in CORE_PLUGINS}
    result: dict[str, str] = {}
    for plugin_id in CORE_PLUGINS:
        plugin_dir = ROOT / plugin_id
        if not (plugin_dir / "manifest.json").exists():
            result[plugin_id] = "missing-source"
            continue
        try:
            process = subprocess.run(
                ["omarchy", "plugin", "validate", str(plugin_dir)],
                cwd=ROOT,
                check=False,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                timeout=30,
            )
        except (OSError, subprocess.TimeoutExpired):
            result[plugin_id] = "unavailable"
            continue
        result[plugin_id] = "pass" if process.returncode == 0 else "fail"
    return result


def report(repo_only: bool) -> dict:
    review = json.loads(REVIEW_FILE.read_text(encoding="utf-8"))
    reviewed_hashes = review.get("upstreamFiles", {})
    omarchy_version = "unknown" if repo_only else package_version("omarchy")
    quickshell_version = "unknown" if repo_only else package_version("quickshell")
    upstream_files = {} if repo_only else {
        name: {
            "path": str(path),
            "exists": path.is_file(),
            "sha256": sha256(path) if path.is_file() else None,
        }
        for name, path in BAR_FILES.items()
    }
    parity = None if repo_only else vendored_parity()
    validation = {plugin_id: "skipped" for plugin_id in CORE_PLUGINS} if repo_only else plugin_validation()

    missing = [name for name, data in upstream_files.items() if not data["exists"]]
    changed = [
        name
        for name, data in upstream_files.items()
        if data["exists"] and reviewed_hashes.get(name) != data["sha256"]
    ]
    validation_failed = [plugin_id for plugin_id, state in validation.items() if state == "fail"]
    if missing or parity is False or validation_failed:
        status = "incompatible"
    elif changed:
        status = "review-required"
    elif not repo_only and (omarchy_version == "unknown" or quickshell_version == "unknown" or parity is None):
        status = "unknown"
    elif not repo_only and not omarchy_version.startswith("4."):
        status = "incompatible"
    else:
        status = "compatible"

    return {
        "status": status,
        "omarchyPath": str(OMARCHY_ROOT),
        "omarchyVersion": omarchy_version,
        "quickshellVersion": quickshell_version,
        "barSourceRevision": omarchy_version if omarchy_version != "unknown" else "unknown",
        "reviewedOmarchyVersion": review.get("reviewedOmarchyVersion", "unknown"),
        "upstreamBarFiles": upstream_files,
        "upstreamReviewRequired": changed,
        "vendoredParity": parity,
        "corePluginValidation": validation,
    }


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--repo-only", action="store_true", help="Skip live package and plugin checks.")
    parser.add_argument("--json", action="store_true", help="Print the report as JSON.")
    parser.add_argument("--check", action="store_true", help="Return non-zero unless the result is compatible.")
    args = parser.parse_args(argv)

    result = report(args.repo_only)
    if args.json:
        print(json.dumps(result, indent=2, sort_keys=True))
    else:
        print(f"Quattro compatibility: {result['status']}")
        print(f"  Omarchy: {result['omarchyVersion']} ({result['omarchyPath']})")
        print(f"  Quickshell: {result['quickshellVersion']}")
        print(f"  Vendored parity: {result['vendoredParity']}")
        if result["upstreamReviewRequired"]:
            print(f"  Review required: {', '.join(result['upstreamReviewRequired'])}")
        for plugin_id, state in result["corePluginValidation"].items():
            print(f"  {plugin_id}: {state}")

    return 0 if not args.check or result["status"] == "compatible" else 1


if __name__ == "__main__":
    raise SystemExit(main())
