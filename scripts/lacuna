#!/usr/bin/env python3
"""Friendly installer for Lacuna Omarchy plugins."""

from __future__ import annotations

import argparse
import json
import os
import shutil
import subprocess
import sys
from dataclasses import dataclass
from datetime import datetime, timezone
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]
DEFAULT_SOURCE = "lacuna"
LEGACY_PLUGIN = "lacuna.compact-pill"
OMARCHY_NATIVE_REPLACEMENT_PLUGINS = {
    "lacuna.audio",
    "lacuna.bluetooth",
    "lacuna.clock",
    "lacuna.idle-inhibitor",
