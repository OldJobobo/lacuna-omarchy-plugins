@dataclass(frozen=True)
class Plugin:
    id: str
    name: str
    kinds: tuple[str, ...]
    standalone: bool
    bundle: str
    requires: tuple[str, ...]
    recommends: tuple[str, ...]
    stability: str = "stable"


def config_home() -> Path:
    return Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config"))


def plugins_dir() -> Path:
    return config_home() / "omarchy" / "plugins"


def lacuna_state_dir() -> Path:
    return config_home() / "omarchy" / "lacuna"


def load_plugins() -> dict[str, Plugin]:
    plugins: dict[str, Plugin] = {}
    for manifest_path in sorted(ROOT.glob("lacuna.*/manifest.json")):
        data = json.loads(manifest_path.read_text(encoding="utf-8"))
        meta = data.get("lacuna", {})
        plugin = Plugin(
            id=data["id"],
            name=data.get("name", data["id"]),
            kinds=tuple(data.get("kinds", [])),
            standalone=bool(meta.get("standalone", False)),
            bundle=meta.get("bundle", "standalone"),
            requires=tuple(meta.get("requires", [])),
            recommends=tuple(meta.get("recommends", [])),
            stability=str(meta.get("stability", "stable")),
        )
        plugins[plugin.id] = plugin
    return plugins


def plugin_order(plugins: dict[str, Plugin]) -> list[str]:
    order: list[str] = []
    for ids in PROFILE_IDS.values():
        for plugin_id in ids:
            if plugin_id in plugins and plugin_id not in order:
                order.append(plugin_id)
    for plugin_id in sorted(plugins):
        if plugin_id not in order:
            order.append(plugin_id)
    return order


def ordered(ids: set[str], plugins: dict[str, Plugin]) -> list[str]:
    priority = plugin_order(plugins)
    return [plugin_id for plugin_id in priority if plugin_id in ids]


def dependency_closure(ids: set[str], plugins: dict[str, Plugin]) -> set[str]:
    resolved = set(ids)
    changed = True
    while changed:
        changed = False
        for plugin_id in list(resolved):
            plugin = plugins.get(plugin_id)
            if not plugin:
                continue
            for required in plugin.requires:
                if required not in resolved:
                    resolved.add(required)
                    changed = True
    return resolved


def full_profile(plugins: dict[str, Plugin], include_legacy: bool, include_replacements: bool) -> set[str]:
    ids = {
        plugin_id
        for plugin_id, plugin in plugins.items()
        if plugin_id != LEGACY_PLUGIN and plugin.bundle != "legacy"
    }
    if not include_replacements:
        ids -= OMARCHY_NATIVE_REPLACEMENT_PLUGINS
    if include_legacy and LEGACY_PLUGIN in plugins:
        ids.add(LEGACY_PLUGIN)
    return ids


def profile_ids(profile: str, plugins: dict[str, Plugin], include_legacy: bool, include_replacements: bool) -> set[str]:
    if profile == "full":
        return full_profile(plugins, include_legacy, include_replacements)
    return {plugin_id for plugin_id in PROFILE_IDS[profile] if plugin_id in plugins}


def installed_lacuna_plugins(plugins: dict[str, Plugin]) -> list[str]:
    base = plugins_dir()
    if not base.exists():
        return []
    ids = []
    for plugin_id in plugins:
        target = base / plugin_id
        if target.exists() or target.is_symlink():
            ids.append(plugin_id)
    return ordered(set(ids), plugins)


def manifest_version(path: Path) -> str:
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return "unknown"
    value = data.get("version")
    return str(value) if value else "unknown"


def repo_plugin_version(plugin_id: str) -> str:
    return manifest_version(ROOT / plugin_id / "manifest.json")


def installed_plugin_version(plugin_id: str) -> str:
    return manifest_version(plugins_dir() / plugin_id / "manifest.json")


def relative_payload_paths(base: Path) -> set[Path]:
    paths: set[Path] = set()
    if not base.exists():
        return paths
    for root, dirs, files in os.walk(base):
        dirs[:] = [name for name in dirs if name != "__pycache__"]
        root_path = Path(root)
        for name in files:
            if name == "__pycache__":
                continue
            paths.add((root_path / name).relative_to(base))
    return paths


def plugin_source_differs(plugin_id: str) -> bool:
    source = ROOT / plugin_id
    target = plugins_dir() / plugin_id
    if not source.is_dir() or not target.is_dir():
        return True

    source_paths = relative_payload_paths(source)
    target_paths = relative_payload_paths(target)
    if source_paths != target_paths:
        return True

    for relative in source_paths:
        source_path = source / relative
        target_path = target / relative
        if source_path.is_symlink() or target_path.is_symlink():
            if not source_path.is_symlink() or not target_path.is_symlink():
                return True
            if os.readlink(source_path) != os.readlink(target_path):
                return True
        elif not filecmp.cmp(source_path, target_path, shallow=False):
            return True
    return False


def has_gum() -> bool:
    return shutil.which("gum") is not None and sys.stdin.isatty() and sys.stdout.isatty()


def run_gum(args: list[str], input_text: str | None = None) -> str | None:
    try:
        result = subprocess.run(
            ["gum", *args],
            input=input_text,
            text=True,
            stdout=subprocess.PIPE,
            stderr=None,
            check=False,
        )
    except OSError:
        return None
    if result.returncode != 0:
        return None
    return result.stdout.strip()


def choose(title: str, choices: list[str]) -> str | None:
    if has_gum():
        return run_gum(["choose", f"--header={title}", *choices])
    print(f"\n{title}")
    for index, choice in enumerate(choices, 1):
        print(f"  {index}. {choice}")
    reply = input("> ").strip()
    if not reply:
        return None
    try:
        return choices[int(reply) - 1]
    except (ValueError, IndexError):
        return None


def multi_choose(title: str, choices: list[str]) -> list[str]:
    if has_gum():
        result = run_gum(["choose", "--no-limit", f"--header={title}", *choices])
        return result.splitlines() if result else []
    print(f"\n{title}")
    for index, choice in enumerate(choices, 1):
        print(f"  {index}. {choice}")
    print("Enter numbers separated by spaces.")
    reply = input("> ").strip()
    selected: list[str] = []
    for token in reply.split():
        try:
            selected.append(choices[int(token) - 1])
        except (ValueError, IndexError):
            continue
    return selected


def confirm(prompt: str, assume_yes: bool) -> bool:
    if assume_yes:
        return True
    if has_gum():
        print(f"\nWaiting for confirmation: {prompt}", flush=True)
        return subprocess.run(["gum", "confirm", prompt], check=False).returncode == 0
    if not sys.stdin.isatty():
        return False
    return input(f"{prompt} [y/N] ").strip().lower().startswith("y")


def label(plugin: Plugin) -> str:
    text = f"{plugin.id} - {plugin.name}"
    if plugin.stability != "stable":
        text += f" [{plugin.stability}]"
    return text


def id_from_label(value: str) -> str:
    return value.split(" - ", 1)[0]


def source_exists(source: str) -> bool | None:
    try:
        result = subprocess.run(
            ["omarchy", "plugin", "source", "list", "--json"],
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            check=False,
        )
    except OSError:
        return None
    if result.returncode != 0:
        return None
    try:
        data = json.loads(result.stdout)
    except json.JSONDecodeError:
        return None
    return any(entry.get("id") == source for entry in data.get("sources", []))


def repo_remote_url() -> str | None:
    result = subprocess.run(
        ["git", "-C", str(ROOT), "remote", "get-url", "origin"],
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        check=False,
    )
    if result.returncode != 0:
        return None
    return result.stdout.strip() or None


def default_source_url() -> str | None:
    if (ROOT / ".git").exists():
        return str(ROOT)
    return repo_remote_url()


def source_catalog_ids() -> set[str] | None:
    try:
        result = subprocess.run(
            ["omarchy-plugin-scan"],
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            check=False,
        )
    except OSError:
        return None
    if result.returncode != 0:
        return None
    try:
        entries = json.loads(result.stdout)
    except json.JSONDecodeError:
        return None
    ids: set[str] = set()
    for entry in entries:
        manifest = entry.get("manifest", {})
        plugin_id = manifest.get("id")
        if isinstance(plugin_id, str):
            ids.add(plugin_id)
    return ids


def checkout_contains_plugins(selected_ids: list[str]) -> bool:
    return all((ROOT / plugin_id / "manifest.json").exists() for plugin_id in selected_ids)


def verify_source_catalog(source: str, selected_ids: list[str]) -> int:
    catalog = source_catalog_ids()
    if catalog is None:
        print("Could not verify Omarchy's source catalog; continuing with install attempt.")
        return 0
    missing = [plugin_id for plugin_id in selected_ids if plugin_id not in catalog]
    if not missing:
        return 0

    if checkout_contains_plugins(selected_ids):
        print("\nOmarchy's source catalog is stale, but this checkout contains the selected plugins.")
        print("Continuing with the local checkout payload.")
        return 0

    print(f"\nSource '{source}' is configured, but Omarchy does not see the selected Lacuna plugins.")
    print("This usually means the source cache points at an older repo state.")
    print("\nRepair this local checkout source with:")
    print(f"  omarchy plugin source remove {source} --yes")
    print(f"  omarchy plugin source add {ROOT} --as {source} --yes")
    print("\nThen rerun the installer.")
    print(f"\nFirst missing plugin: {missing[0]}")
    return 1


def print_plan(title: str, ids: list[str], plugins: dict[str, Plugin]) -> None:
    print(f"\n{title}")
    if not ids:
        print("  Nothing selected.")
        return
    for plugin_id in ids:
        plugin = plugins[plugin_id]
        kind_text = ", ".join(plugin.kinds) or "plugin"
        print(f"  - {plugin.id} ({kind_text})")


def stage_commands(ids: list[str], rescan: bool = True) -> list[str]:
    commands = [f"stage {plugin_id} -> {plugins_dir() / plugin_id}" for plugin_id in ids]
    if ids and rescan:
        commands.append("omarchy plugin rescan")
    return commands


def shell_config_path() -> Path:
    return config_home() / "omarchy" / "shell.json"


def default_shell_config() -> dict:
    return {
        "version": 1,
        "bar": {"layout": {"left": [], "center": [], "right": []}},
        "plugins": [],
    }


def stock_shell_config() -> dict:
    for path in OMARCHY_STOCK_SHELL_CONFIG_PATHS:
        if not path.exists():
            continue
        try:
            data = json.loads(path.read_text(encoding="utf-8"))
        except json.JSONDecodeError:
            continue
        if isinstance(data, dict):
            return ensure_shell_config_shape(data)
    return {
        "version": 1,
        "bar": {
            "centerAnchor": "omarchy.clock",
            "layout": {
                "left": [{"id": "omarchy.menu"}, {"id": "omarchy.workspaces"}],
                "center": [{"id": "omarchy.clock", "format": "dddd HH:mm"}],
                "right": [{"id": "omarchy.audio"}],
            },
        },
        "plugins": [],
    }


def read_shell_config() -> dict:
    path = shell_config_path()
    if not path.exists():
        return default_shell_config()
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as error:
        raise SystemExit(f"Could not parse {path}: {error}") from error
    if not isinstance(data, dict):
        raise SystemExit(f"{path} must contain a JSON object.")
    return data


def ensure_shell_config_shape(config: dict) -> dict:
    config.setdefault("version", 1)
    bar = config.setdefault("bar", {})
    if not isinstance(bar, dict):
        config["bar"] = bar = {}
    layout = bar.setdefault("layout", {})
    if not isinstance(layout, dict):
        bar["layout"] = layout = {}
    for section in ("left", "center", "right"):
        if not isinstance(layout.get(section), list):
            layout[section] = []
    if not isinstance(config.get("plugins"), list):
        config["plugins"] = []
    return config


def write_shell_config(config: dict) -> None:
    path = shell_config_path()
    path.parent.mkdir(parents=True, exist_ok=True)
    payload = json.dumps(config, indent=2) + "\n"
    tmp = path.with_suffix(".json.tmp")
    tmp.write_text(payload, encoding="utf-8")
    tmp.replace(path)


def entry_id(entry: object) -> str | None:
    if isinstance(entry, dict) and isinstance(entry.get("id"), str):
        return entry["id"]
    return None


def remove_shell_entries(config: dict, plugin_id: str) -> list[dict]:
    removed: list[dict] = []
    layout = config["bar"]["layout"]
    for section in ("left", "center", "right"):
        kept = []
        for entry in layout[section]:
            if entry_id(entry) == plugin_id:
                if isinstance(entry, dict):
                    removed.append(entry)
            else:
                kept.append(entry)
        layout[section] = kept

    kept_plugins = []
    for entry in config["plugins"]:
        if entry_id(entry) == plugin_id:
            if isinstance(entry, dict):
                removed.append(entry)
        else:
            kept_plugins.append(entry)
    config["plugins"] = kept_plugins

    if config["bar"].get("id") == plugin_id:
        del config["bar"]["id"]

    return removed


def restore_stock_bar_config(config: dict) -> None:
    current_bar = config.get("bar", {})
    if not isinstance(current_bar, dict):
        current_bar = {}

    stock_bar = stock_shell_config().get("bar", {})
    if not isinstance(stock_bar, dict):
        stock_bar = default_shell_config()["bar"]
    stock_bar = json.loads(json.dumps(stock_bar))

    for key, value in current_bar.items():
        if key not in {"id", "layout", "centerAnchor"}:
            stock_bar[key] = value

    stock_bar.pop("id", None)
    config["bar"] = stock_bar
    ensure_shell_config_shape(config)


def has_shell_entry(config: dict, plugin_id: str) -> bool:
    if config["bar"].get("id") == plugin_id:
        return True
    layout = config["bar"]["layout"]
    for section in ("left", "center", "right"):
        if any(entry_id(entry) == plugin_id for entry in layout[section]):
            return True
    return any(entry_id(entry) == plugin_id for entry in config["plugins"])


def is_bar_widget(plugin: Plugin) -> bool:
    return "bar-widget" in plugin.kinds


def is_bar_option(plugin: Plugin) -> bool:
    return "bar" in plugin.kinds


def enable_shell_entry(config: dict, plugin: Plugin) -> None:
    if is_bar_option(plugin):
        config["bar"]["id"] = plugin.id
    elif is_bar_widget(plugin):
        removed = remove_shell_entries(config, plugin.id)
        entry = next((item for item in removed if entry_id(item) == plugin.id), {"id": plugin.id})
        config["bar"]["layout"]["right"].append(entry)
    elif not has_shell_entry(config, plugin.id):
        config["plugins"].append({"id": plugin.id})


def layout_template_entries() -> list[tuple[str, int, dict]]:
    entries: list[tuple[str, int, dict]] = []
    for section in ("left", "center", "right"):
        for index, item in enumerate(LACUNA_BAR_LAYOUT[section]):
            entries.append((section, index, dict(item)))
    return entries


def example_layout_entries() -> list[tuple[str, int, dict]]:
    path = ROOT / "config" / "shell.lacuna-native-replacements.example.json"
    data = json.loads(path.read_text(encoding="utf-8"))
    entries: list[tuple[str, int, dict]] = []
    for section in ("left", "center", "right"):
        for index, item in enumerate(data.get("bar", {}).get("layout", {}).get(section, [])):
            plugin_id = item.get("id") if isinstance(item, dict) else None
            if isinstance(plugin_id, str) and plugin_id.startswith("lacuna."):
                entries.append((section, index, dict(item)))
    return entries


def apply_layout_to_config(config: dict, selected: set[str]) -> None:
    for section, index, template_entry in example_layout_entries():
        plugin_id = template_entry["id"]
        if plugin_id not in selected:
            continue
        removed = remove_shell_entries(config, plugin_id)
        entry = next((item for item in removed if entry_id(item) == plugin_id), template_entry)
        for key, value in template_entry.items():
            entry.setdefault(key, value)
        target = config["bar"]["layout"][section]
        target.insert(min(index, len(target)), entry)


def apply_lacuna_bar_layout_to_config(config: dict, available: set[str]) -> None:
    removed_by_id: dict[str, dict] = {}
    layout = config["bar"]["layout"]
    for section in ("left", "center", "right"):
        for item in layout[section]:
            plugin_id = entry_id(item)
            if plugin_id and plugin_id in LACUNA_BAR_LAYOUT_PLUGIN_IDS and isinstance(item, dict):
                removed_by_id.setdefault(plugin_id, item)
            if plugin_id and plugin_id in OMARCHY_TO_LACUNA_REPLACEMENTS and isinstance(item, dict):
                lacuna_id = OMARCHY_TO_LACUNA_REPLACEMENTS[plugin_id]
                migrated = dict(item)
                migrated["id"] = lacuna_id
                removed_by_id.setdefault(lacuna_id, migrated)
        layout[section] = []

    for section, index, template_entry in layout_template_entries():
        plugin_id = template_entry["id"]
        if plugin_id.startswith("lacuna.") and plugin_id not in available:
            continue
        entry = removed_by_id.get(plugin_id, dict(template_entry))
        for key, value in template_entry.items():
            entry.setdefault(key, value)
        target = config["bar"]["layout"][section]
        target.insert(min(index, len(target)), entry)
    pin_bar_size_toggle_last(layout["right"])
    config["bar"]["centerAnchor"] = "lacuna.clock"


def pin_bar_size_toggle_last(entries: list[dict]) -> None:
    toggles = [entry for entry in entries if entry_id(entry) == "lacuna.bar-size-pill"]
    if not toggles:
        return
    entries[:] = [entry for entry in entries if entry_id(entry) != "lacuna.bar-size-pill"]
    entries.extend(toggles)


def activation_reload_command(selected: set[str]) -> list[str]:
    if "lacuna.bar" in selected:
        return ["omarchy", "restart", "shell"]
    return ["omarchy", "plugin", "rescan"]


def activation_reload_label(selected: set[str]) -> str:
    command = activation_reload_command(selected)
    return " ".join(command)


def activate_plugins(ids: list[str], plugins: dict[str, Plugin], selected: set[str], apply_layout_choice: bool, dry_run: bool) -> int:
    if not ids:
        return 0
    if dry_run:
        print(f"  update {shell_config_path()} once")
        if "lacuna.bar" in selected:
            print("  apply Lacuna bar host layout in shell.json")
        print(f"  {activation_reload_label(selected)}")
        return 0

    config = ensure_shell_config_shape(read_shell_config())
    for plugin_id in ids:
        enable_shell_entry(config, plugins[plugin_id])
    if "lacuna.bar" in selected or config["bar"].get("id") == "lacuna.bar":
        available = selected | set(installed_lacuna_plugins(plugins))
        apply_lacuna_bar_layout_to_config(config, available)
    if apply_layout_choice:
        apply_layout_to_config(config, selected)
    write_shell_config(config)
    print(f"  updated {shell_config_path()}", flush=True)
    return run_command(activation_reload_command(selected), dry_run)


def deactivate_plugins(ids: list[str], dry_run: bool) -> int:
    if not ids:
        return 0
    if dry_run:
        print(f"  update {shell_config_path()} once")
        return 0

    config = ensure_shell_config_shape(read_shell_config())
    for plugin_id in ids:
        remove_shell_entries(config, plugin_id)
    if "lacuna.bar" in ids:
        restore_stock_bar_config(config)
    write_shell_config(config)
    print(f"  updated {shell_config_path()}", flush=True)
    return 0


def uninstall_reload_command(ids: list[str]) -> list[str]:
    if "lacuna.bar" in ids:
        return ["omarchy", "restart", "shell"]
    return ["omarchy", "plugin", "rescan"]


def uninstall_reload_label(ids: list[str]) -> str:
    return " ".join(uninstall_reload_command(ids))


def activation_commands(ids: list[str], apply_layout_choice: bool = False) -> list[str]:
    commands = []
    if ids:
        commands.append(f"update {shell_config_path()} once")
        if "lacuna.bar" in ids:
            commands.append("apply Lacuna bar host layout in shell.json")
        if apply_layout_choice:
            commands.append("apply Lacuna bar layout in shell.json")
        commands.append(activation_reload_label(set(ids)))
    return commands


def uninstall_stage_commands(ids: list[str]) -> list[str]:
    commands = []
    if ids:
        commands.append(f"update {shell_config_path()} once")
    if "lacuna.bar" in ids:
        commands.append("restore stock Omarchy bar layout in shell.json")
    for plugin_id in ids:
        commands.append(f"remove {plugins_dir() / plugin_id}")
    if ids:
        commands.append(uninstall_reload_label(ids))
    return commands


def print_stage_commands(commands: list[str]) -> None:
    for command in commands:
        print("  " + command)


def run_command(command: list[str], dry_run: bool, timeout_seconds: int = 60) -> int:
    if dry_run:
        print("  " + " ".join(command))
        return 0
    print("  " + " ".join(command), flush=True)
    try:
        return subprocess.run(command, check=False, timeout=timeout_seconds).returncode
    except subprocess.TimeoutExpired:
        print(f"Command timed out after {timeout_seconds}s: {' '.join(command)}")
        return 124


def run_commands(commands: list[list[str]], dry_run: bool) -> int:
    for command in commands:
        code = run_command(command, dry_run)
        if code != 0:
            return code
    return 0


def remove_path(path: Path) -> None:
    if path.is_symlink() or path.is_file():
        path.unlink()
    elif path.exists():
        shutil.rmtree(path)


def backup_target(target: Path) -> Path | None:
    if not target.exists() and not target.is_symlink():
        return None
    if target.is_symlink():
        target.unlink()
        return None

    timestamp = datetime.now(timezone.utc).strftime("%Y%m%d%H%M%S")
    base = target.parent / f".{target.name}.bak.{timestamp}"
    backup = base
    suffix = 1
    while backup.exists():
        backup = target.parent / f"{base.name}-{suffix}"
        suffix += 1
    shutil.move(str(target), str(backup))
    prune_backups(target.name)
    return backup


def prune_backups(plugin_id: str, keep: int = BACKUPS_TO_KEEP) -> None:
    if keep < 0:
        keep = 0
    base = plugins_dir()
    backups = sorted(
        base.glob(f".{plugin_id}.bak.*"),
        key=lambda path: (path.stat().st_mtime, path.name),
        reverse=True,
    )
    for backup in backups[keep:]:
        remove_path(backup)


def validate_plugin(plugin_id: str, source_dir: Path, dry_run: bool) -> int:
    command = ["omarchy", "plugin", "validate", str(source_dir)]
    if dry_run:
        print("  " + " ".join(command))
        return 0
    return run_command(command, dry_run=False)


def stage_plugin(plugin_id: str, dry_run: bool, reinstall: bool) -> int:
    source_dir = ROOT / plugin_id
    target = plugins_dir() / plugin_id
    if not source_dir.is_dir():
        print(f"Missing plugin source directory: {source_dir}")
        return 1
    if (target.exists() or target.is_symlink()) and not reinstall:
        print(f"  {plugin_id} already staged")
        return 0

    print(f"  stage {plugin_id} -> {target}", flush=True)
    code = validate_plugin(plugin_id, source_dir, dry_run)
    if code != 0:
        return code
    if dry_run:
        return 0

    target.parent.mkdir(parents=True, exist_ok=True)
    stage = target.parent / f".{plugin_id}.tmp.{os.getpid()}"
    remove_path(stage)
    backup = None
    try:
        shutil.copytree(
            source_dir,
            stage,
            symlinks=True,
            ignore=shutil.ignore_patterns("__pycache__"),
        )
        backup = backup_target(target)
        shutil.move(str(stage), str(target))
    except Exception as error:
        remove_path(stage)
        if backup and backup.exists() and not target.exists():
            shutil.move(str(backup), str(target))
        print(f"Failed to stage {plugin_id}: {error}")
        return 1
    if backup:
        print(f"    previous install backed up to {backup}")
    return 0


def stage_plugins(ids: list[str], dry_run: bool, reinstall: bool, rescan: bool = True) -> int:
    for plugin_id in ids:
        code = stage_plugin(plugin_id, dry_run, reinstall)
        if code != 0:
            return code
    if ids and rescan:
        return run_command(["omarchy", "plugin", "rescan"], dry_run)
    return 0


def remove_plugin(plugin_id: str, dry_run: bool) -> int:
    target = plugins_dir() / plugin_id
    print(f"  remove {target}", flush=True)
    if dry_run:
        return 0
    if not target.exists() and not target.is_symlink():
        print(f"    {plugin_id} is not installed")
        return 0
    backup = backup_target(target)
    if backup:
        print(f"    backed up to {backup}")
    else:
        print(f"    removed {plugin_id}")
    return 0


def uninstall_plugins(ids: list[str], dry_run: bool) -> int:
    code = deactivate_plugins(ids, dry_run)
    if code != 0:
        return code
    for plugin_id in ids:
        code = remove_plugin(plugin_id, dry_run)
        if code != 0:
            return code
    if ids:
        return run_command(uninstall_reload_command(ids), dry_run)
    return 0


def ensure_source(source: str, source_url: str | None, dry_run: bool, assume_yes: bool) -> int:
    exists = False if dry_run else source_exists(source)
    if exists is True:
        return 0
    if exists is None and not dry_run:
        print("Could not verify Omarchy plugin sources; continuing with install attempt.")
        return 0

    url = source_url or default_source_url()
    if not url:
        print(f"Plugin source '{source}' is not configured.")
        print(f"Add it first: omarchy plugin source add <repo-url> --as {source}")
        return 1

    command = ["omarchy", "plugin", "source", "add", url, "--as", source]
    if assume_yes:
        command.append("--yes")
    print(f"\nPlugin source '{source}' is not configured.")
    if not confirm(f"Add trusted plugin source '{source}' from {url}?", assume_yes):
        print(f"Add it later with: omarchy plugin source add {url} --as {source}")
        return 1
    print("\nAdding plugin source")
    print("This clones the trusted source into Omarchy's plugin cache and can take a moment.", flush=True)
    return run_command(command, dry_run)


def resolve_install_selection(args: argparse.Namespace, plugins: dict[str, Plugin]) -> set[str]:
    if args.plugins:
        selected = {item for value in args.plugins for item in value.split(",") if item}
    else:
        selected = profile_ids(args.profile, plugins, args.include_legacy, args.include_replacements)

    unknown = sorted(selected - set(plugins))
    if unknown:
        raise SystemExit(f"Unknown Lacuna plugin id: {', '.join(unknown)}")

    selected = dependency_closure(selected, plugins)
    if args.include_recommended:
        for plugin_id in list(selected):
            selected.update(plugins[plugin_id].recommends)
        selected = dependency_closure(selected, plugins)
    if not args.include_legacy:
        selected.discard(LEGACY_PLUGIN)
    if args.profile == "full" and not args.include_replacements and not args.plugins:
        selected -= OMARCHY_NATIVE_REPLACEMENT_PLUGINS
    return selected


def is_default_full_install(args: argparse.Namespace) -> bool:
    return args.profile == "full" and not args.plugins


def apply_full_install_defaults(args: argparse.Namespace) -> None:
    if not is_default_full_install(args):
        return
    args.include_replacements = True
    if args.activate is None:
        args.activate = True
    if args.apply_layout is None:
        args.apply_layout = True


def install(args: argparse.Namespace) -> int:
    apply_full_install_defaults(args)
    plugins = load_plugins()
    selected = resolve_install_selection(args, plugins)
    ids = ordered(selected, plugins)
    installed = set(installed_lacuna_plugins(plugins))
    install_ids = ids if args.reinstall else [plugin_id for plugin_id in ids if plugin_id not in installed]
    source_state = None if args.dry_run else source_exists(args.source)

    apply_layout_choice = args.apply_layout
    if apply_layout_choice is None:
        apply_layout_choice = False

    activate_choice = args.activate
    if activate_choice is None and not args.yes and not args.dry_run:
        activate_choice = confirm(
            "Enable selected Lacuna plugins now? Full activation reloads the shell once.",
            False,
        )
    elif activate_choice is None:
        activate_choice = False

    print_plan("Install plan", ids, plugins)
    if installed and not args.reinstall:
        already = [plugin_id for plugin_id in ids if plugin_id in installed]
        if already:
            print("\nAlready installed; will not reinstall unless --reinstall is passed:")
            for plugin_id in already:
                print(f"  - {plugin_id}")
    if source_state is False:
        print(f"\nSource '{args.source}' is not configured yet; the installer will offer to add it before installing.")
    commands = stage_commands(install_ids, rescan=not activate_choice)
    print("\nCommands")
    if commands:
        print_stage_commands(commands)
    else:
        print("  No plugin copy commands needed.")

    if activate_choice:
        print("\nActivation")
        if args.dry_run:
            print_stage_commands(activation_commands(ids, apply_layout_choice))
        else:
            print(f"  Will update shell.json once for {len(ids)} selected Lacuna plugins.")
        if apply_layout_choice:
            if not args.dry_run:
                print("  Will apply the recommended Lacuna bar layout in the same shell.json update.")
    elif apply_layout_choice:
        print("\nLayout was requested, but plugins will not be enabled. Re-run with --activate --apply-layout to apply it.")

    if args.dry_run:
        return 0
    if not confirm("Install selected Lacuna plugins?", args.yes):
        print("Install cancelled.")
        return 1
    code = ensure_source(args.source, args.source_url, args.dry_run, args.yes)
    if code != 0:
        return code
    code = verify_source_catalog(args.source, ids)
    if code != 0:
        return code
    if install_ids:
        code = stage_plugins(install_ids, args.dry_run, args.reinstall, rescan=not activate_choice)
        if code != 0:
            return code
    if activate_choice:
        code = activate_plugins(ids, plugins, selected, apply_layout_choice, args.dry_run)
    else:
        print("\nInstalled files are staged but disabled.")
        print("Enable a smaller profile first, for example:")
        print("  ./scripts/lacuna install --profile core --activate")
    return code


def uninstall(args: argparse.Namespace) -> int:
    plugins = load_plugins()
    if args.plugins:
        selected = {item for value in args.plugins for item in value.split(",") if item}
    elif args.all:
        selected = set(installed_lacuna_plugins(plugins))
    else:
        if sys.stdin.isatty() and not args.yes and not args.dry_run:
            next_args = uninstall_menu(args)
            return uninstall(next_args) if next_args else 0
        print("Refusing to uninstall every Lacuna plugin implicitly. Pass --all or --plugin.", file=sys.stderr)
        return 2

    unknown = sorted(selected - set(plugins))
    if unknown:
        raise SystemExit(f"Unknown Lacuna plugin id: {', '.join(unknown)}")

    ids = ordered(selected, plugins)
    print_plan("Uninstall plan", ids, plugins)
    commands = uninstall_stage_commands(ids)
    if commands:
        print("\nCommands")
        print_stage_commands(commands)
    if args.purge_state:
        print(f"\nPurge state: {lacuna_state_dir()}")

    if args.dry_run:
        return 0
    if not ids and not args.purge_state:
        print("No installed Lacuna plugins found.")
        return 0
    if not confirm("Remove selected Lacuna plugins?", args.yes):
        print("Uninstall cancelled.")
        return 1
    code = uninstall_plugins(ids, args.dry_run)
    if code != 0:
        return code
    if args.purge_state:
        state_dir = lacuna_state_dir()
        if state_dir.exists() and confirm(f"Delete Lacuna runtime state at {state_dir}?", args.yes):
            shutil.rmtree(state_dir)
            print(f"Deleted {state_dir}")
    return 0


def resolve_update_selection(args: argparse.Namespace, plugins: dict[str, Plugin]) -> list[str]:
    installed = set(installed_lacuna_plugins(plugins))
    if args.plugins:
        selected = {item for value in args.plugins for item in value.split(",") if item}
        unknown = sorted(selected - set(plugins))
        if unknown:
            raise SystemExit(f"Unknown Lacuna plugin id: {', '.join(unknown)}")

        missing = ordered(selected - installed, plugins)
        for plugin_id in missing:
            print(f"  {plugin_id} is not installed; skipping.")
        selected &= installed
    else:
        selected = installed
    return ordered(selected, plugins)


def update(args: argparse.Namespace) -> int:
    plugins = load_plugins()
    ids = resolve_update_selection(args, plugins)
    update_ids = [plugin_id for plugin_id in ids if plugin_source_differs(plugin_id)]

    print_plan("Update plan", update_ids, plugins)
    if ids and len(update_ids) != len(ids):
        unchanged = [plugin_id for plugin_id in ids if plugin_id not in update_ids]
        print(f"\nAlready current: {len(unchanged)} plugin(s)")

    print("\nCommands")
    commands = stage_commands(update_ids, rescan=True)
    if commands:
        print_stage_commands(commands)
    else:
        print("  No plugin copy commands needed.")

    if args.dry_run:
        return 0
    if not update_ids:
        print("\nNo installed Lacuna plugins need updates.")
        for plugin_id in ids:
            prune_backups(plugin_id)
        return 0
    if not confirm("Update changed Lacuna plugins?", args.yes):
        print("Update cancelled.")
        return 1
    for plugin_id in ids:
        prune_backups(plugin_id)
    return stage_plugins(update_ids, args.dry_run, reinstall=True, rescan=True)


def status(_args: argparse.Namespace) -> int:
    plugins = load_plugins()
    installed = set(installed_lacuna_plugins(plugins))
    try:
        shell_config = ensure_shell_config_shape(read_shell_config())
        enabled = {plugin_id for plugin_id in plugins if has_shell_entry(shell_config, plugin_id)}
    except SystemExit:
        enabled = set()

    print("Lacuna status")
    print(f"  Source configured: {source_exists(DEFAULT_SOURCE)}")
    print(f"  Installed plugins: {len(installed)}")
    for plugin_id in ordered(installed, plugins):
        state = "enabled" if plugin_id in enabled else "staged"
        installed_version = installed_plugin_version(plugin_id)
        repo_version = repo_plugin_version(plugin_id)
        print(f"  - {plugin_id} ({state}) installed {installed_version}, repo {repo_version}")
    if not installed:
        print("  No Lacuna plugins are installed.")
    return 0


def custom_install_menu(args: argparse.Namespace) -> argparse.Namespace | None:
    plugins = load_plugins()
    selected: set[str] = set()
    group_choices = [PROFILE_LABELS[key] for key in PROFILE_IDS]
    picked_groups = multi_choose("Choose Lacuna groups to install", group_choices)
    reverse = {value: key for key, value in PROFILE_LABELS.items()}
    for group in picked_groups:
        selected.update(PROFILE_IDS[reverse[group]])

    standalone = [
        label(plugin)
        for plugin in plugins.values()
        if plugin.standalone and plugin.id not in selected
    ]
    picked_plugins = multi_choose("Add individual standalone plugins", sorted(standalone))
    selected.update(id_from_label(item) for item in picked_plugins)

    if not selected:
        print("Nothing selected.")
        return None
    args.profile = "core"
    args.plugins = [",".join(sorted(selected))]
    args.include_recommended = True
    return args


def uninstall_menu(args: argparse.Namespace) -> argparse.Namespace | None:
    plugins = load_plugins()
    installed = installed_lacuna_plugins(plugins)
    if not installed:
        print("No installed Lacuna plugins found.")
        return None
    action = choose("Uninstall Lacuna", ["Remove all Lacuna plugins", "Choose plugins", "Cancel"])
    if action == "Remove all Lacuna plugins":
        args.all = True
        return args
    if action == "Choose plugins":
        picked = multi_choose("Choose installed plugins to remove", [label(plugins[item]) for item in installed])
        if not picked:
            return None
        args.plugins = [",".join(id_from_label(item) for item in picked)]
        return args
    return None


def menu(args: argparse.Namespace) -> int:
    action = choose(
        "Lacuna",
        [
            "Full Lacuna install",
            "Custom install",
            "Update installed Lacuna plugins",
            "Uninstall Lacuna",
            "Status",
            "Exit",
        ],
    )
    if action == "Full Lacuna install":
        args.command = "install"
        args.profile = "full"
        args.plugins = []
        args.include_recommended = False
        args.include_replacements = True
        args.activate = True
        args.apply_layout = True
        print("\nFull install will stage and activate the Lacuna Bar setup.")
        print("It will select lacuna.bar, apply the Lacuna bar layout, and restart Omarchy shell once.")
        return install(args)
    if action == "Custom install":
        args.command = "install"
        next_args = custom_install_menu(args)
        return install(next_args) if next_args else 0
    if action == "Update installed Lacuna plugins":
        args.command = "update"
        return update(args)
    if action == "Uninstall Lacuna":
        args.command = "uninstall"
        next_args = uninstall_menu(args)
        return uninstall(next_args) if next_args else 0
    if action == "Status":
        return status(args)
    return 0


def common_parser() -> argparse.ArgumentParser:
    common = argparse.ArgumentParser(add_help=False)
    common.add_argument("--source", default=argparse.SUPPRESS, help="Omarchy plugin source id. Default: lacuna")
    common.add_argument("--source-url", default=argparse.SUPPRESS, help="Git URL to add when the source is missing.")
    common.add_argument(
        "--dry-run",
        action="store_true",
        default=argparse.SUPPRESS,
        help="Print the plan and commands without changing anything.",
    )
    common.add_argument("--yes", "-y", action="store_true", default=argparse.SUPPRESS, help="Skip confirmation prompts.")
    common.add_argument(
        "--include-legacy",
        action="store_true",
        default=argparse.SUPPRESS,
        help="Include legacy bundle plugins.",
    )
    common.add_argument(
        "--include-replacements",
        action="store_true",
        default=argparse.SUPPRESS,
        help="Include Lacuna replacements for native Omarchy bar widgets in the full profile.",
    )
    return common


def parser() -> argparse.ArgumentParser:
    common = common_parser()
    base = argparse.ArgumentParser(
        description="Install, uninstall, and inspect Lacuna Omarchy plugins.",
        parents=[common],
    )

    subparsers = base.add_subparsers(dest="command")

    install_parser = subparsers.add_parser("install", parents=[common], help="Install Lacuna plugins.")
    install_parser.add_argument("--profile", choices=["full", *PROFILE_IDS.keys()], default="full")
    install_parser.add_argument("--plugin", dest="plugins", action="append", default=[], help="Plugin id or comma list.")
    install_parser.add_argument("--include-recommended", action="store_true", help="Include recommended companion plugins.")
    install_parser.add_argument("--reinstall", action="store_true", help="Replace plugins that are already installed.")
    activate = install_parser.add_mutually_exclusive_group()
    activate.add_argument("--activate", action="store_true", default=None, help="Enable plugins after installing them.")
    activate.add_argument("--no-activate", dest="activate", action="store_false", help="Install files but leave plugins disabled.")
    layout = install_parser.add_mutually_exclusive_group()
    layout.add_argument("--apply-layout", action="store_true", default=None, help="Apply the recommended Lacuna bar layout.")
    layout.add_argument("--keep-layout", dest="apply_layout", action="store_false", help="Do not modify the bar layout.")

    uninstall_parser = subparsers.add_parser("uninstall", parents=[common], help="Uninstall Lacuna plugins.")
    uninstall_parser.add_argument("--all", action="store_true", help="Remove all installed Lacuna plugins.")
    uninstall_parser.add_argument("--plugin", dest="plugins", action="append", default=[], help="Plugin id or comma list.")
    uninstall_parser.add_argument("--purge-state", action="store_true", help="Also remove ~/.config/omarchy/lacuna after confirmation.")

    update_parser = subparsers.add_parser("update", parents=[common], help="Restage installed Lacuna plugins that changed in this checkout.")
    update_parser.add_argument("--plugin", dest="plugins", action="append", default=[], help="Plugin id or comma list.")

    subparsers.add_parser("status", parents=[common], help="Show installed Lacuna plugins.")
    return base


def normalize_args(args: argparse.Namespace) -> argparse.Namespace:
    if not hasattr(args, "source"):
        args.source = DEFAULT_SOURCE
    if not hasattr(args, "source_url"):
        args.source_url = None
    if not hasattr(args, "dry_run"):
        args.dry_run = False
    if not hasattr(args, "yes"):
        args.yes = False
    if not hasattr(args, "include_legacy"):
        args.include_legacy = False
    if not hasattr(args, "include_replacements"):
        args.include_replacements = False
    if not hasattr(args, "plugins"):
        args.plugins = []
    if not hasattr(args, "profile"):
        args.profile = "full"
    if not hasattr(args, "include_recommended"):
        args.include_recommended = False
    if not hasattr(args, "reinstall"):
        args.reinstall = False
    if not hasattr(args, "activate"):
        args.activate = None
    if not hasattr(args, "apply_layout"):
        args.apply_layout = None
    if not hasattr(args, "all"):
        args.all = False
    if not hasattr(args, "purge_state"):
        args.purge_state = False
    return args


def main(argv: list[str] | None = None) -> int:
    args = normalize_args(parser().parse_args(argv))
    try:
        if args.command == "install":
            return install(args)
        if args.command == "uninstall":
            return uninstall(args)
        if args.command == "update":
            return update(args)
        if args.command == "status":
            return status(args)
        if sys.stdin.isatty():
            return menu(args)
        parser().print_help()
        return 0
    except KeyboardInterrupt:
        print("\nInterrupted. Installed plugins may be staged; check with: omarchy plugin list")
        return 130


if __name__ == "__main__":
    raise SystemExit(main())
