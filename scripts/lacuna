    "lacuna.weather",
    "lacuna.workspaces",
}

PROFILE_IDS = {
    "core": [
        "lacuna.state",
        "lacuna.shell-settings",
        "lacuna.menu",
        "lacuna.menu-button",
    ],
    "theme": [
        "lacuna.theme",
