{
  "schemaVersion": 1,
  "id": "omarchy.lacuna-nightlight",
  "name": "Lacuna Night Light",
  "version": "0.1.0",
  "author": "Lacuna",
  "description": "Lacuna-styled night light status module for the Omarchy bar.",
  "kinds": ["bar-widget"],
  "activation": "on-demand",
  "entryPoints": {
    "barWidget": "Widget.qml"
  },
  "barWidget": {
    "displayName": "Lacuna Night Light",
    "description": "Shows and toggles Omarchy night light state.",
    "category": "Lacuna",
    "allowMultiple": false,
    "defaults": {
      "showInactive": false,
      "interval": 5000
    },
    "schema": [
      { "key": "showInactive", "type": "boolean", "label": "Show when inactive", "default": false },
      { "key": "interval", "type": "number", "label": "Refresh interval (ms)", "default": 5000 },
      { "key": "colorProfile", "type": "enum", "label": "Color profile", "options": ["semantic", "colorful"], "description": "Override the global Lacuna color profile for this widget." }
    ]
  }
}
