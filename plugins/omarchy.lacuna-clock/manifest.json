{
  "schemaVersion": 1,
  "id": "omarchy.lacuna-clock",
  "name": "Lacuna Clock",
  "version": "0.1.0",
  "author": "Lacuna",
  "description": "Lacuna-styled clock for the Omarchy bar.",
  "kinds": ["bar-widget"],
  "activation": "on-demand",
  "entryPoints": {
    "barWidget": "Widget.qml"
  },
  "barWidget": {
    "displayName": "Lacuna Clock",
    "description": "Shows the current time with Lacuna sizing and hover treatment.",
    "category": "Lacuna",
    "allowMultiple": false,
    "defaults": {
      "format": "ddd d h:mm AP",
      "formatAlt": "dd MMMM 'W'ww yyyy",
      "verticalFormat": "HH\n—\nmm"
    },
    "schema": [
      { "key": "format", "type": "string", "label": "Horizontal format" },
      { "key": "formatAlt", "type": "string", "label": "Alternate format" },
      { "key": "verticalFormat", "type": "string", "label": "Vertical format" },
      { "key": "colorProfile", "type": "enum", "label": "Color profile", "options": ["semantic", "colorful"], "description": "Override the global Lacuna color profile for this widget." }
    ]
  }
}
