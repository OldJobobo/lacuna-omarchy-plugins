{
  "schemaVersion": 1,
  "id": "omarchy.lacuna-crt-overlay",
  "name": "Lacuna CRT Overlay",
  "version": "0.1.0",
  "author": "Lacuna",
  "description": "Subtle CRT scanlines with a slow broad static band for animated wallpaper ambience.",
  "kinds": ["overlay"],
  "activation": "persistent",
  "keepLoaded": true,
  "entryPoints": {
    "overlay": "Overlay.qml"
  },
  "defaults": {
    "effectEnabled": true,
    "foregroundOverlay": false,
    "intensity": 0.58,
    "speed": 1,
    "scanlineSpacing": 3,
    "staticBandHeight": 150,
    "staticAmount": 0.24,
    "glowAmount": 0.22,
    "bloomPulse": true,
    "bloomPulseAmount": 0.52,
    "bloomPulseInterval": 18000,
    "distortion": true,
    "distortionAmount": 0.45,
    "vignette": true
  },
  "schema": [
    {
      "key": "effectEnabled",
      "type": "boolean",
      "label": "Effect enabled"
    },
    {
      "key": "foregroundOverlay",
      "type": "boolean",
      "label": "Foreground overlay"
    },
    {
      "key": "intensity",
      "type": "number",
      "label": "Intensity"
    },
    {
      "key": "speed",
      "type": "number",
      "label": "Speed"
    },
    {
      "key": "scanlineSpacing",
      "type": "number",
      "label": "Scanline spacing"
    },
    {
      "key": "staticBandHeight",
      "type": "number",
      "label": "Static band height"
    },
    {
      "key": "staticAmount",
      "type": "number",
      "label": "Static amount"
    },
    {
      "key": "glowAmount",
      "type": "number",
      "label": "Glow amount"
    },
    {
      "key": "bloomPulse",
      "type": "boolean",
      "label": "Bloom pulse"
    },
    {
      "key": "bloomPulseAmount",
      "type": "number",
      "label": "Bloom pulse amount"
    },
    {
      "key": "bloomPulseInterval",
      "type": "number",
      "label": "Bloom pulse interval"
    },
    {
      "key": "distortion",
      "type": "boolean",
      "label": "Foreground distortion"
    },
    {
      "key": "distortionAmount",
      "type": "number",
      "label": "Distortion amount"
    },
    {
      "key": "vignette",
      "type": "boolean",
      "label": "Vignette"
    }
  ]
}
