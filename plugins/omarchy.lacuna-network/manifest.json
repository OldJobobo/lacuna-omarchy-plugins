{
  "schemaVersion": 1,
  "id": "omarchy.lacuna-network",
  "name": "Lacuna Network",
  "version": "0.1.0",
  "author": "Lacuna",
  "description": "Lacuna-styled network status control for the Omarchy bar.",
  "kinds": ["bar-widget"],
  "activation": "on-demand",
  "entryPoints": {
    "barWidget": "Widget.qml"
  },
  "barWidget": {
    "displayName": "Lacuna Network",
    "description": "Shows active network status.",
    "category": "Lacuna",
    "allowMultiple": false,
    "defaults": {
      "interval": 5000
    },
    "schema": [
      { "key": "interval", "type": "integer", "label": "Refresh interval (ms)", "min": 1000, "step": 1000 },
      { "key": "colorProfile", "type": "enum", "label": "Color profile", "options": ["semantic", "colorful"], "description": "Override the global Lacuna color profile for this widget." }
    ]
  }
}
