{
  "schemaVersion": 1,
  "id": "lacuna.weather",
  "name": "Lacuna Weather",
  "version": "0.1.0",
  "author": "Lacuna",
  "description": "Lacuna weather status with an attached current-conditions and forecast flyout.",
  "kinds": [
    "bar-widget"
  ],
  "activation": "on-demand",
  "entryPoints": {
    "barWidget": "Widget.qml"
  },
  "barWidget": {
    "displayName": "Lacuna Weather",
    "description": "Shows current conditions and opens a four-day weather flyout.",
    "category": "Lacuna",
    "allowMultiple": false,
    "defaults": {
      "interval": 900000,
      "location": "",
      "unit": "auto",
      "showText": true,
      "colorProfile": "semantic"
    },
    "schema": [
      {
        "key": "interval",
        "type": "integer",
        "label": "Refresh interval (ms)",
        "min": 60000,
        "step": 60000,
        "defaultValue": 900000
      },
      {
        "key": "location",
        "type": "string",
        "label": "Location override",
        "description": "Leave blank to infer the location from the network.",
        "defaultValue": ""
      },
      {
        "key": "unit",
        "type": "enum",
        "label": "Temperature unit",
        "options": [
          "auto",
          "imperial",
          "metric"
        ],
        "defaultValue": "auto"
      },
      {
        "key": "showText",
        "type": "boolean",
        "label": "Show text",
        "defaultValue": true
      },
      {
        "key": "colorProfile",
        "type": "enum",
        "label": "Color profile",
        "options": [
          "semantic",
          "colorful"
        ],
        "description": "Override the global Lacuna color profile for this widget.",
        "defaultValue": "semantic"
      }
    ]
  },
  "lacuna": {
    "standalone": true,
    "bundle": "standalone",
    "requires": [],
    "recommends": []
  }
}
