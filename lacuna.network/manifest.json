{
  "schemaVersion": 1,
  "id": "lacuna.network",
  "name": "Lacuna Network",
  "version": "0.1.0",
  "author": "Lacuna",
  "description": "Lacuna network provider, bar pill, and panel backed by Omarchy's NetworkManager data.",
  "kinds": [
    "service",
    "panel",
    "bar-widget"
  ],
  "activation": "persistent",
  "keepLoaded": true,
  "entryPoints": {
    "service": "Service.qml",
    "panel": "Panel.qml",
    "barWidget": "Widget.qml"
  },
  "barWidget": {
    "displayName": "Lacuna Network",
    "description": "Shows active network status.",
    "category": "Lacuna",
    "allowMultiple": false,
    "defaults": {
      "interval": 5000,
      "colorProfile": "semantic"
    },
    "schema": [
      {
        "key": "interval",
        "type": "integer",
        "label": "Refresh interval (ms)",
        "min": 1000,
        "step": 1000,
        "defaultValue": 5000
      },
      {
        "key": "colorProfile",
        "type": "enum",
        "label": "Color profile",
        "options": [
          "semantic",
          "colorful"
        ],
        "description": "Override the global Lacuna color profile for this widget.",
        "defaultValue": "semantic"
      }
    ]
  },
  "lacuna": {
    "standalone": true,
    "bundle": "standalone",
    "requires": [],
    "recommends": []
  }
}
