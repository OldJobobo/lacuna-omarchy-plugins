{
  "schemaVersion": 1,
  "id": "lacuna.indicators",
  "name": "Lacuna Indicators",
  "version": "0.1.0",
  "author": "Lacuna",
  "description": "Lacuna-styled manual state indicators for the Omarchy bar.",
  "kinds": [
    "bar-widget"
  ],
  "activation": "on-demand",
  "entryPoints": {
    "barWidget": "Widget.qml"
  },
  "barWidget": {
    "displayName": "Lacuna Indicators",
    "description": "Shows DND, night light, idle, recording, and dictation state indicators.",
    "category": "Lacuna",
    "allowMultiple": false,
    "defaults": {
      "items": [
        "Dnd",
        "NightLight",
        "StayAwake",
        "ScreenRecording",
        "Dictation"
      ],
      "showInactive": false,
      "colorProfile": "semantic"
    },
    "schema": [
      {
        "key": "items",
        "type": "multiselect",
        "label": "Indicators",
        "options": [
          "Dnd",
          "NightLight",
          "StayAwake",
          "ScreenRecording",
          "Dictation"
        ],
        "noSelectionText": "None selected",
        "defaultValue": [
          "Dnd",
          "NightLight",
          "StayAwake",
          "ScreenRecording",
          "Dictation"
        ]
      },
      {
        "key": "showInactive",
        "type": "boolean",
        "label": "Show inactive indicators",
        "defaultValue": false
      },
      {
        "key": "colorProfile",
        "type": "enum",
        "label": "Color profile",
        "options": [
          "semantic",
          "colorful"
        ],
        "description": "Override the global Lacuna color profile for this widget.",
        "defaultValue": "semantic"
      }
    ]
  },
  "lacuna": {
    "standalone": true,
    "bundle": "standalone",
    "requires": [],
    "recommends": []
  }
}
