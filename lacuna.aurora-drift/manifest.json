{
  "schemaVersion": 1,
  "id": "lacuna.aurora-drift",
  "name": "Lacuna Aurora Drift",
  "version": "0.1.0",
  "author": "Lacuna",
  "description": "Subtle bottom-layer aurora ribbons for animated wallpaper ambience.",
  "kinds": [
    "overlay"
  ],
  "activation": "persistent",
  "keepLoaded": true,
  "entryPoints": {
    "overlay": "Overlay.qml"
  },
  "defaults": {
    "effectEnabled": true,
    "intensity": 0.95,
    "speed": 1.35,
    "ribbonCount": 6,
    "blurSoftness": 0.9,
    "accentBlend": 0.88,
    "vignette": true
  },
  "schema": [
    {
      "key": "effectEnabled",
      "type": "boolean",
      "label": "Effect enabled",
      "defaultValue": true
    },
    {
      "key": "intensity",
      "type": "number",
      "label": "Intensity",
      "defaultValue": 0.95
    },
    {
      "key": "speed",
      "type": "number",
      "label": "Speed",
      "defaultValue": 1.35
    },
    {
      "key": "ribbonCount",
      "type": "number",
      "label": "Ribbon count",
      "defaultValue": 6
    },
    {
      "key": "blurSoftness",
      "type": "number",
      "label": "Ribbon softness",
      "defaultValue": 0.9
    },
    {
      "key": "accentBlend",
      "type": "number",
      "label": "Accent blend",
      "defaultValue": 0.88
    },
    {
      "key": "vignette",
      "type": "boolean",
      "label": "Vignette",
      "defaultValue": true
    }
  ],
  "lacuna": {
    "standalone": true,
    "bundle": "standalone",
    "requires": [],
    "recommends": []
  }
}
