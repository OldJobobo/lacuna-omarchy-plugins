{
  "schemaVersion": 1,
  "id": "lacuna.idle-inhibitor",
  "name": "Lacuna Idle Inhibitor",
  "version": "0.1.0",
  "author": "Lacuna",
  "description": "Lacuna-styled idle inhibition status module for the Omarchy bar.",
  "kinds": [
    "bar-widget"
  ],
  "activation": "on-demand",
  "entryPoints": {
    "barWidget": "Widget.qml"
  },
  "barWidget": {
    "displayName": "Lacuna Idle Inhibitor",
    "description": "Shows when idle locking and screensaver are inhibited.",
    "category": "Lacuna",
    "allowMultiple": false,
    "defaults": {
      "showInactive": true,
      "interval": 5000,
      "colorProfile": "semantic"
    },
    "schema": [
      {
        "key": "showInactive",
        "type": "boolean",
        "label": "Show when inactive",
        "default": true,
        "defaultValue": true
      },
      {
        "key": "interval",
        "type": "number",
        "label": "Refresh interval (ms)",
        "default": 5000,
        "defaultValue": 5000
      },
      {
        "key": "colorProfile",
        "type": "enum",
        "label": "Color profile",
        "options": [
          "semantic",
          "colorful"
        ],
        "description": "Override the global Lacuna color profile for this widget.",
        "defaultValue": "semantic"
      }
    ]
  },
  "lacuna": {
    "standalone": true,
    "bundle": "standalone",
    "requires": [],
    "recommends": []
  }
}
