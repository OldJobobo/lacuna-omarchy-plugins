#!/usr/bin/env python3
import argparse
import json
import urllib.parse


def clean_server_url(value):
    return str(value or "").strip().rstrip("/")


def load_config(raw):
    try:
        return json.loads(raw or "{}")
    except json.JSONDecodeError:
        return {}


def main(argv=None):
    parser = argparse.ArgumentParser()
    parser.add_argument("--config-json", required=True)
    parser.add_argument("--item-id", required=True)
    parser.add_argument("--media-type", default="video")
    args = parser.parse_args(argv)

    config = load_config(args.config_json)
    server_url = clean_server_url(config.get("serverUrl"))
    api_key = str(config.get("apiKey") or "").strip()
    item_id = str(args.item_id or "").strip()

    if config.get("enabled") is not True or not server_url or not api_key or not item_id:
        print(json.dumps({"url": "", "thumbnail": "", "error": "Jellyfin is not configured"}))
        return 1

    query = urllib.parse.urlencode({"api_key": api_key})
    image_query = urllib.parse.urlencode({"fillWidth": 420, "quality": 90, "api_key": api_key})
    quoted_id = urllib.parse.quote(item_id)
    print(json.dumps({
        "url": f"{server_url}/Items/{quoted_id}/Download?{query}",
        "thumbnail": f"{server_url}/Items/{quoted_id}/Images/Primary?{image_query}",
        "mediaType": "audio" if str(args.media_type).lower() == "audio" else "video",
        "error": "",
    }))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
