#!/usr/bin/env python3
import json
import os
import shutil
import subprocess
import sys


def load_config(raw):
    try:
        payload = json.loads(raw or "{}")
    except json.JSONDecodeError:
        return {}
    return payload if isinstance(payload, dict) else {}


def ytdlp_auth_args(config):
    if config.get("enabled") is not True:
        return []
    cookies_file = str(config.get("cookiesFile") or "").strip()
    if cookies_file:
        return ["--cookies", os.path.expanduser(cookies_file)]
    cookies_from_browser = str(config.get("cookiesFromBrowser") or "").strip()
    if cookies_from_browser:
        return ["--cookies-from-browser", cookies_from_browser]
    return []


def main(argv=None):
    argv = list(argv or sys.argv[1:])
    config = {}
    if argv[:1] == ["--config-json"]:
        config = load_config(argv[1] if len(argv) > 1 else "{}")
        argv = argv[2:]
    if not argv:
        print(json.dumps({"url": "", "error": "missing url"}))
        return 1

    ytdlp = shutil.which("yt-dlp")
    if not ytdlp:
        print(json.dumps({"url": "", "error": "yt-dlp is not installed"}))
        return 1

    cmd = [
        ytdlp,
        *ytdlp_auth_args(config),
        "--no-warnings",
        "--no-playlist",
        "--get-url",
        "-f",
        "22/18/best[height<=720][ext=mp4][vcodec!=none][acodec!=none]/best[ext=mp4][vcodec!=none][acodec!=none]",
        argv[0],
    ]
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=18, check=False)
    except subprocess.TimeoutExpired:
        print(json.dumps({"url": "", "error": "background stream timed out"}))
        return 1

    if result.returncode != 0:
        message = (result.stderr or result.stdout or "background stream failed").strip().splitlines()
        print(json.dumps({"url": "", "error": message[-1] if message else "background stream failed"}))
        return 1

    for line in result.stdout.splitlines():
        url = line.strip()
        if url.startswith("http"):
            print(json.dumps({"url": url, "error": ""}))
            return 0

    print(json.dumps({"url": "", "error": "no background stream"}))
    return 1


if __name__ == "__main__":
    raise SystemExit(main())
