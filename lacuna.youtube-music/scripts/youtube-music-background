#!/usr/bin/env python3
import json
import os
import shutil
import subprocess
import sys

YOUTUBE_PLAYER_CLIENT = "web_embedded"
BACKGROUND_FORMAT = "18/best[ext=mp4][vcodec!=none][acodec!=none]"


def load_config(raw):
    try:
        payload = json.loads(raw or "{}")
    except json.JSONDecodeError:
        return {}
    return payload if isinstance(payload, dict) else {}


def ytdlp_auth_args(config):
    if config.get("enabled") is not True:
        return []
    cookies_file = str(config.get("cookiesFile") or "").strip()
    if cookies_file:
        return ["--cookies", os.path.expanduser(cookies_file)]
    cookies_from_browser = str(config.get("cookiesFromBrowser") or "").strip()
    if cookies_from_browser:
        return ["--cookies-from-browser", cookies_from_browser]
    return []


def build_cmd(ytdlp, config, url, embedded_client):
    cmd = [
        ytdlp,
        *ytdlp_auth_args(config),
        "--no-warnings",
        "--no-playlist",
        "--get-url",
        "-f",
        BACKGROUND_FORMAT,
        url,
    ]
    if embedded_client:
        cmd[1:1] = ["--extractor-args", f"youtube:player_client={YOUTUBE_PLAYER_CLIENT}"]
    return cmd


def run_ytdlp(ytdlp, config, url, embedded_client):
    try:
        return subprocess.run(
            build_cmd(ytdlp, config, url, embedded_client),
            capture_output=True,
            text=True,
            timeout=18,
            check=False,
        )
    except subprocess.TimeoutExpired:
        return None


def result_error(result, fallback):
    if result is None:
        return "background stream timed out"
    message = (result.stderr or result.stdout or fallback).strip().splitlines()
    return message[-1] if message else fallback


def main(argv=None):
    argv = list(argv or sys.argv[1:])
    config = {}
    if argv[:1] == ["--config-json"]:
        config = load_config(argv[1] if len(argv) > 1 else "{}")
        argv = argv[2:]
    if not argv:
        print(json.dumps({"url": "", "error": "missing url"}))
        return 1

    ytdlp = shutil.which("yt-dlp")
    if not ytdlp:
        print(json.dumps({"url": "", "error": "yt-dlp is not installed"}))
        return 1

    result = run_ytdlp(ytdlp, config, argv[0], True)
    if result is None or result.returncode != 0:
        fallback_result = run_ytdlp(ytdlp, config, argv[0], False)
        if fallback_result is not None and fallback_result.returncode == 0:
            result = fallback_result

    if result is None or result.returncode != 0:
        print(json.dumps({"url": "", "error": result_error(result, "background stream failed")}))
        return 1

    for line in result.stdout.splitlines():
        url = line.strip()
        if url.startswith("http"):
            print(json.dumps({"url": url, "error": ""}))
            return 0

    print(json.dumps({"url": "", "error": "no background stream"}))
    return 1


if __name__ == "__main__":
    raise SystemExit(main())
