#!/usr/bin/env python3
import json
import os
import re
import subprocess
import sys
import tempfile
from pathlib import Path


PLACEHOLDER_TITLE = re.compile(r"^YouTube video(?: [A-Za-z0-9_-]+)?$")


def is_placeholder(item):
    title = str(item.get("title") or "")
    url = str(item.get("url") or item.get("webpage_url") or "")
    provider = str(item.get("provider") or "youtube")
    return provider == "youtube" and url.startswith("http") and PLACEHOLDER_TITLE.match(title) is not None


def resolve_track(info_script, url):
    try:
        result = subprocess.run([info_script, url], capture_output=True, text=True, timeout=25, check=False)
    except subprocess.TimeoutExpired:
        return None, "Metadata lookup timed out"

    if result.returncode != 0:
        return None, "Metadata lookup failed"

    try:
        payload = json.loads(result.stdout or "{}")
    except json.JSONDecodeError:
        return None, "Metadata lookup returned invalid JSON"

    error = str(payload.get("error") or "")
    track = payload.get("track")
    return track if isinstance(track, dict) else None, error


def merge_track(item, track):
    next_item = dict(item)
    for key in ["id", "title", "uploader", "thumbnail", "source", "url"]:
        value = track.get(key)
        if value:
            next_item[key] = str(value)
    duration = track.get("durationText") or track.get("duration")
    if duration:
        next_item["duration"] = str(duration)
    next_item["provider"] = str(next_item.get("provider") or "youtube")
    next_item["mediaType"] = str(next_item.get("mediaType") or "video")
    next_item["streamKind"] = str(next_item.get("streamKind") or "video")
    return next_item


def write_json_atomic(path, payload):
    path.parent.mkdir(parents=True, exist_ok=True)
    fd, tmp_name = tempfile.mkstemp(prefix=f".{path.name}.", suffix=".tmp", dir=str(path.parent))
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as handle:
            json.dump(payload, handle, indent=2)
            handle.write("\n")
        os.replace(tmp_name, path)
    finally:
        try:
            os.unlink(tmp_name)
        except FileNotFoundError:
            pass


def main(argv=None) -> int:
    args = list(sys.argv[1:] if argv is None else argv)
    if len(args) != 2:
        print(json.dumps({"changed": 0, "checked": 0, "error": "Usage: media-player-refresh-favorites STATE_FILE INFO_SCRIPT"}))
        return 0

    state_file = Path(args[0]).expanduser()
    info_script = args[1]
    if not state_file.exists():
        print(json.dumps({"changed": 0, "checked": 0, "error": "State file does not exist"}))
        return 0

    try:
        state = json.loads(state_file.read_text(encoding="utf-8") or "{}")
    except json.JSONDecodeError:
        print(json.dumps({"changed": 0, "checked": 0, "error": "State file is not valid JSON"}))
        return 0

    favorites = state.get("favorites")
    if not isinstance(favorites, list):
        print(json.dumps({"changed": 0, "checked": 0, "error": ""}))
        return 0

    changed = 0
    checked = 0
    errors = []
    next_favorites = []
    for item in favorites:
        if not isinstance(item, dict) or not is_placeholder(item):
            next_favorites.append(item)
            continue

        checked += 1
        url = str(item.get("url") or item.get("webpage_url") or "")
        track, error = resolve_track(info_script, url)
        if track and not PLACEHOLDER_TITLE.match(str(track.get("title") or "")):
            next_favorites.append(merge_track(item, track))
            changed += 1
        else:
            next_favorites.append(item)
            if error:
                errors.append(error)

    if changed:
        state["favorites"] = next_favorites
        write_json_atomic(state_file, state)

    print(json.dumps({
        "changed": changed,
        "checked": checked,
        "error": " / ".join(errors[:3]),
    }))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
