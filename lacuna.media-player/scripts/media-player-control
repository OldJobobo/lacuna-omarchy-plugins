#!/usr/bin/env python3
import argparse
import json
import os
import socket
import subprocess
import sys
import time

YOUTUBE_PLAYER_CLIENT = "web_embedded"


def send(socket_path, payload):
    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as client:
        client.settimeout(1.5)
        client.connect(socket_path)
        client.sendall((json.dumps(payload) + "\n").encode("utf-8"))


def request_many(socket_path, commands, timeout=1.5):
    """Send several mpv commands over one IPC connection.

    mpv broadcasts event lines to every IPC client, so replies must be matched
    by request_id rather than taken as "the next line". Returns a dict of
    request_id -> reply for every reply that arrived before the deadline.
    """
    replies = {}
    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as client:
        client.settimeout(timeout)
        client.connect(socket_path)
        wire = b""
        for request_id, command in commands.items():
            wire += (json.dumps({"command": command, "request_id": request_id}) + "\n").encode("utf-8")
        client.sendall(wire)

        deadline = time.monotonic() + timeout
        buffer = b""
        while len(replies) < len(commands) and time.monotonic() < deadline:
            try:
                chunk = client.recv(4096)
            except OSError:
                break
            if not chunk:
                break
            buffer += chunk
            while b"\n" in buffer:
                line, buffer = buffer.split(b"\n", 1)
                if not line.strip():
                    continue
                try:
                    message = json.loads(line.decode("utf-8", errors="replace"))
                except ValueError:
                    continue
                if not isinstance(message, dict) or "event" in message:
                    continue
                request_id = message.get("request_id")
                if request_id is None:
                    # Very old mpv builds omit request_id; replies still arrive
                    # in command order, so match the first unanswered command.
                    request_id = next((rid for rid in commands if rid not in replies), None)
                if request_id in commands and request_id not in replies:
                    replies[request_id] = message
    return replies


def request(socket_path, payload):
    replies = request_many(socket_path, {1: payload.get("command", [])})
    return replies.get(1, {})


def pid_path(socket_path):
    return os.path.join(os.path.dirname(socket_path), "mpv.pid")


def read_pid(socket_path):
    try:
        return int(open(pid_path(socket_path), encoding="utf-8").read().strip())
    except (OSError, ValueError):
        return 0


def pid_alive(pid):
    if pid <= 0:
        return False
    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    except OSError:
        return False
    return True


def pid_matches_player(pid, socket_path):
    if not pid_alive(pid):
        return False
    try:
        raw = open(f"/proc/{pid}/cmdline", "rb").read()
    except OSError:
        return False
    argv = [part.decode("utf-8", errors="replace") for part in raw.split(b"\0") if part]
    if not argv or os.path.basename(argv[0]) != "mpv":
        return False
    return f"--input-ipc-server={socket_path}" in argv


def cleanup_socket(socket_path):
    try:
        if os.path.exists(socket_path):
            send(socket_path, {"command": ["quit"]})
    except OSError:
        pass

    pid_file = pid_path(socket_path)
    try:
        pid = int(open(pid_file, encoding="utf-8").read().strip())
        if pid_matches_player(pid, socket_path):
            os.kill(pid, 15)
    except (OSError, ValueError):
        pass

    for path in [socket_path, pid_file]:
        try:
            if os.path.exists(path):
                os.unlink(path)
        except OSError:
            pass


def ytdl_raw_options(args):
    options = [f"extractor-args=youtube:player_client={YOUTUBE_PLAYER_CLIENT}"]
    if args.cookies_from_browser:
        options.append(f"cookies-from-browser={args.cookies_from_browser}")
    if args.cookies_file:
        options.append(f"cookies={args.cookies_file}")
    return ",".join(options)


def start(args):
    os.makedirs(args.runtime_dir, mode=0o700, exist_ok=True)
    log_path = os.path.join(args.runtime_dir, "mpv.log")
    cleanup_socket(args.socket)

    command = [
        "mpv",
        "--idle=no",
        # Hold the process and IPC socket open at end-of-file so the shell can
        # observe eof-reached and advance the queue, instead of inferring a
        # failure from a vanished socket.
        "--keep-open=yes",
        "--force-window=no",
        f"--input-ipc-server={args.socket}",
        "--ytdl-format=18/best[height<=360][ext=mp4]/bestaudio[ext=m4a]/best",
        "--cache=yes",
        "--cache-pause=yes",
        "--cache-pause-initial=yes",
        "--cache-pause-wait=10",
        "--cache-secs=300",
        "--demuxer-readahead-secs=180",
        "--demuxer-max-bytes=512MiB",
        "--audio-buffer=1",
        "--network-timeout=30",
        f"--volume={args.volume}",
        f"--start={max(0, args.start)}",
        f"--log-file={log_path}",
        "--msg-level=all=warn",
        "--term-playing-msg=",
        f"--ytdl-raw-options={ytdl_raw_options(args)}",
    ]
    if args.audio_only:
        command.append("--no-video")
    command.append(args.url)
    proc = subprocess.Popen(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, start_new_session=True)
    with open(pid_path(args.socket), "w", encoding="utf-8") as handle:
        handle.write(str(proc.pid))
    print(json.dumps({"ok": True}))
    return 0


def command(args):
    try:
        payload = json.loads(args.payload)
        send(args.socket, payload)
        if payload.get("command", [""])[0] == "quit":
            cleanup_socket(args.socket)
        print(json.dumps({"ok": True}))
        return 0
    except Exception as exc:
        print(json.dumps({"ok": False, "error": str(exc)}))
        return 1


def get_property(args):
    try:
        response = request(args.socket, {"command": ["get_property", args.name]})
        print(json.dumps({"ok": response.get("error") == "success", "value": response.get("data")}))
        return 0
    except Exception as exc:
        print(json.dumps({"ok": False, "error": str(exc)}))
        return 1


def probe(args):
    """One-shot playback health probe.

    Always prints a JSON object and exits 0, so callers can rely on the
    payload alone:
      ok         - mpv answered over IPC (fields below are trustworthy)
      running    - the recorded mpv pid is alive (mpv may still be starting)
      eofReached - playback finished (mpv is holding via --keep-open)
      idleActive - mpv dropped to idle with no file loaded
      paused     - mpv-side pause state (includes the --keep-open eof hold)
      timePos    - current position in seconds, or null while loading
      duration   - track duration in seconds, or null while loading
    """
    result = {
        "ok": False,
        "running": pid_alive(read_pid(args.socket)),
        "eofReached": False,
        "idleActive": False,
        "paused": False,
        "timePos": None,
        "duration": None,
        "error": "",
    }
    commands = {
        1: ["get_property", "eof-reached"],
        2: ["get_property", "idle-active"],
        3: ["get_property", "pause"],
        4: ["get_property", "time-pos"],
        5: ["get_property", "duration"],
    }
    try:
        replies = request_many(args.socket, commands)
    except Exception as exc:
        result["error"] = str(exc)
        print(json.dumps(result))
        return 0

    def value_of(request_id):
        message = replies.get(request_id) or {}
        if message.get("error") != "success":
            return None
        return message.get("data")

    if replies:
        result["ok"] = True
        result["running"] = True
        result["eofReached"] = value_of(1) is True
        result["idleActive"] = value_of(2) is True
        result["paused"] = value_of(3) is True
        time_pos = value_of(4)
        duration = value_of(5)
        result["timePos"] = float(time_pos) if isinstance(time_pos, (int, float)) else None
        result["duration"] = float(duration) if isinstance(duration, (int, float)) else None
    else:
        result["error"] = "no reply from mpv"

    print(json.dumps(result))
    return 0


def main(argv=None):
    parser = argparse.ArgumentParser()
    sub = parser.add_subparsers(dest="action", required=True)

    start_parser = sub.add_parser("start")
    start_parser.add_argument("--socket", required=True)
    start_parser.add_argument("--runtime-dir", required=True)
    start_parser.add_argument("--url", required=True)
    start_parser.add_argument("--volume", type=int, default=70)
    start_parser.add_argument("--start", type=float, default=0)
    start_parser.add_argument("--cookies-from-browser", default="")
    start_parser.add_argument("--cookies-file", default="")
    mode = start_parser.add_mutually_exclusive_group()
    mode.add_argument("--audio-only", action="store_true")
    mode.add_argument("--video", action="store_true")

    command_parser = sub.add_parser("command")
    command_parser.add_argument("--socket", required=True)
    command_parser.add_argument("--payload", required=True)

    get_parser = sub.add_parser("get-property")
    get_parser.add_argument("--socket", required=True)
    get_parser.add_argument("--name", required=True)

    probe_parser = sub.add_parser("probe")
    probe_parser.add_argument("--socket", required=True)

    cleanup_parser = sub.add_parser("cleanup")
    cleanup_parser.add_argument("--socket", required=True)

    args = parser.parse_args(argv)
    if args.action == "start":
        return start(args)
    if args.action == "cleanup":
        cleanup_socket(args.socket)
        print(json.dumps({"ok": True}))
        return 0
    if args.action == "get-property":
        return get_property(args)
    if args.action == "probe":
        return probe(args)
    return command(args)


if __name__ == "__main__":
    raise SystemExit(main())
