#!/usr/bin/env python3
import argparse
import json
import os
import shutil
import subprocess
import sys


def duration_text(value):
    try:
        seconds = int(float(value))
    except (TypeError, ValueError):
        return ""
    minutes, second = divmod(seconds, 60)
    hours, minute = divmod(minutes, 60)
    if hours:
        return f"{hours}:{minute:02d}:{second:02d}"
    return f"{minute}:{second:02d}"


def thumbnail(entry):
    thumbs = entry.get("thumbnails")
    if isinstance(thumbs, list) and thumbs:
        for item in reversed(thumbs):
            url = item.get("url") if isinstance(item, dict) else ""
            if url:
                return url
    return entry.get("thumbnail") or ""


def normalize(entry):
    video_id = str(entry.get("id") or entry.get("videoId") or "")
    webpage_url = entry.get("webpage_url") or entry.get("url") or ""
    if webpage_url and webpage_url.startswith("http"):
        url = webpage_url
    elif video_id:
        url = f"https://www.youtube.com/watch?v={video_id}"
    else:
        url = ""

    return {
        "id": video_id,
        "title": entry.get("title") or "Untitled video",
        "uploader": entry.get("uploader") or entry.get("channel") or "",
        "description": entry.get("description") or "",
        "durationText": duration_text(entry.get("duration")),
        "thumbnail": f"https://i.ytimg.com/vi/{video_id}/hqdefault.jpg" if video_id else thumbnail(entry),
        "url": url,
    }


def load_config(raw):
    try:
        payload = json.loads(raw or "{}")
    except json.JSONDecodeError:
        return {}
    return payload if isinstance(payload, dict) else {}


def ytdlp_auth_args(config):
    if config.get("enabled") is not True:
        return []
    cookies_file = str(config.get("cookiesFile") or "").strip()
    if cookies_file:
        return ["--cookies", os.path.expanduser(cookies_file)]
    cookies_from_browser = str(config.get("cookiesFromBrowser") or "").strip()
    if cookies_from_browser:
        return ["--cookies-from-browser", cookies_from_browser]
    return []


def parse_duration(text):
    if not text:
        return None
    parts = str(text).split(":")
    try:
        total = 0
        for part in parts:
            total = total * 60 + int(part)
        return total
    except ValueError:
        return None


def music_score(item):
    title = str(item.get("title") or "").lower()
    uploader = str(item.get("uploader") or "").lower()
    description = str(item.get("description") or "").lower()
    haystack = f"{title} {uploader} {description}"
    score = 0
    for term in ["official audio", "official music video", "music video", "lyrics", "lyric video", "audio", "song", "provided to youtube by"]:
        if term in haystack:
            score += 4
    for term in ["full album", "album", "mix", "mixtape", "dj set", "live set", "live stream", "livestream", "concert", "playlist", "boiler room", "tiny desk", "session"]:
        if term in haystack:
            score += 5
    if " - topic" in uploader or uploader.endswith("topic"):
        score += 8
    if " - " in title:
        score += 2
    for term in ["reaction", "review", "tutorial", "podcast", "interview", "explained", "documentary", "lesson", "how to", "covering ", "ranking"]:
        if term in haystack:
            score -= 14
    duration = parse_duration(item.get("durationText"))
    if duration is not None:
        if 45 <= duration <= 600:
            score += 2
        elif 900 < duration <= 14400:
            score += 2
        elif duration < 30:
            score -= 10
    return score


def disqualified(item):
    title = str(item.get("title") or "").lower()
    uploader = str(item.get("uploader") or "").lower()
    description = str(item.get("description") or "").lower()
    haystack = f"{title} {uploader} {description}"
    return any(term in haystack for term in ["reaction", "review", "tutorial", "podcast", "interview", "explained", "documentary", "lesson", "how to"])


def filtered_music_rows(rows, limit):
    preferred = [item for item in rows if music_score(item) >= 4]
    fallback = [item for item in rows if item not in preferred and not disqualified(item)]
    usable = preferred + fallback
    if not usable:
        usable = rows
    for item in usable:
        item.pop("description", None)
    return usable[:limit]


def filtered_home_music_rows(rows, limit):
    preferred = [item for item in rows if music_score(item) >= 4 and not disqualified(item)]
    if not preferred:
        preferred = [item for item in rows if music_score(item) >= 2 and not disqualified(item)]
    preferred.sort(key=lambda item: (-music_score(item), item.get("_index", 0)))
    for item in preferred:
        item.pop("_index", None)
        item.pop("description", None)
        item["source"] = "YouTube Home Music"
    return preferred[:limit]


def ytdlp_results(ytdlp, query, limit, config=None, search_filter="all"):
    search_limit = max(40, min(80, limit * 3))
    cmd = [
        ytdlp,
        *ytdlp_auth_args(config or {}),
        "--flat-playlist",
        "--dump-json",
        "--skip-download",
        "--no-warnings",
        f"ytsearch{search_limit}:{query}",
    ]
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=20, check=False)
    except subprocess.TimeoutExpired:
        return [], "Search timed out"

    if result.returncode != 0:
        message = (result.stderr or result.stdout or "Search failed").strip().splitlines()
        return [], message[-1] if message else "Search failed"

    rows = []
    for index, line in enumerate(result.stdout.splitlines()):
        line = line.strip()
        if not line:
            continue
        try:
            entry = json.loads(line)
        except json.JSONDecodeError:
            continue
        item = normalize(entry)
        if item["url"]:
            item["_index"] = index
            item["source"] = "YouTube"
            rows.append(item)

    if search_filter == "music":
        rows.sort(key=lambda item: (-music_score(item), item.get("_index", 0)))
    else:
        rows.sort(key=lambda item: item.get("_index", 0))
    for item in rows:
        item.pop("_index", None)
    if search_filter == "music":
        return filtered_music_rows(rows, limit), ""
    for item in rows:
        item.pop("description", None)
    return rows[:limit], ""


def youtube_home_results(ytdlp, limit, config=None, music_only=False):
    playlist_limit = max(1, min(80 if music_only else 40, max(limit, limit * 4 if music_only else limit)))
    cmd = [
        ytdlp,
        *ytdlp_auth_args(config or {}),
        "--playlist-items",
        f"1-{playlist_limit}",
        "--flat-playlist",
        "--dump-json",
        "--skip-download",
        "--no-warnings",
        "https://www.youtube.com/",
    ]
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=25, check=False)
    except subprocess.TimeoutExpired:
        return [], "YouTube home timed out"

    if result.returncode != 0:
        message = (result.stderr or result.stdout or "YouTube home failed").strip().splitlines()
        return [], message[-1] if message else "YouTube home failed"

    stderr = result.stderr or ""
    if "could not be decrypted" in stderr or "Extracted 0 cookies" in stderr:
        return [], "YouTube login cookies could not be read; reconnect YouTube or install the browser keyring support yt-dlp needs"

    rows = []
    seen = set()
    for index, line in enumerate(result.stdout.splitlines()):
        line = line.strip()
        if not line:
            continue
        try:
            entry = json.loads(line)
        except json.JSONDecodeError:
            continue
        item = normalize(entry)
        url = item["url"]
        if not url or url in seen:
            continue
        seen.add(url)
        item["_index"] = index
        item["source"] = "YouTube Home"
        rows.append(item)
        if not music_only and len(rows) >= limit:
            break
    if music_only:
        return filtered_home_music_rows(rows, limit), ""
    for item in rows:
        item.pop("_index", None)
        item.pop("description", None)
    return rows, ""


def main(argv=None) -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--config-json", default="{}")
    parser.add_argument("--filter", choices=["all", "music"], default="all")
    parser.add_argument("--limit", type=int, default=8)
    parser.add_argument("--suggestions", action="store_true")
    parser.add_argument("query", nargs="?")
    args = parser.parse_args(argv)

    ytdlp = shutil.which("yt-dlp")
    config = load_config(args.config_json)
    limit = max(1, min(80, args.limit))
    query = str(args.query or "").strip()

    if not ytdlp:
        print(json.dumps({"results": [], "error": "yt-dlp is not installed"}))
        return 0

    if args.suggestions and config.get("enabled") is True:
        rows, error = youtube_home_results(ytdlp, limit, config, args.filter == "music")
        if rows or error:
            print(json.dumps({"results": rows, "error": error}))
            return 0
        print(json.dumps({"results": [], "error": "YouTube login did not return a personalized home feed"}))
        return 0

    if args.suggestions:
        fallback_query = str(config.get("defaultSuggestionsQuery") or "official music videos").strip()
        query = fallback_query or "official music videos"

    if not query:
        print(json.dumps({"results": [], "error": ""}))
        return 0

    rows, error = ytdlp_results(ytdlp, query, limit, config, args.filter)
    print(json.dumps({"results": rows, "error": error}))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
